PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<WrittenWork>

<WrittenWork> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/WrittenWork> ] ;
  <http://dbpedia.org/ontology/abbreviation> xsd:string ? ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/author> @<Person> + ;
  <http://dbpedia.org/ontology/characterInPlay> xsd:string * ;
  <http://dbpedia.org/ontology/chiefEditor> @<Person> * ;
  <http://dbpedia.org/ontology/circulation> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/city> @<City> ? ;
  <http://dbpedia.org/ontology/coden> xsd:string ? ;
  <http://dbpedia.org/ontology/country> @<Country> ? ;
  <http://dbpedia.org/ontology/coverArtist> @<Person> * ;
  <http://dbpedia.org/ontology/dcc> xsd:string ? ;
  <http://dbpedia.org/ontology/depictionDescription> rdf:langString ;
  <http://dbpedia.org/ontology/editor> @<Agent> * ;
  <http://dbpedia.org/ontology/editorTitle> rdf:langString ? ;
  <http://dbpedia.org/ontology/finalPublicationYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/firstPublicationDate> xsd:date ? ;
  <http://dbpedia.org/ontology/firstPublicationYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/foundingDate> xsd:date ? ;
  <http://dbpedia.org/ontology/frequencyOfPublication> xsd:string * ;
  <http://dbpedia.org/ontology/genre> @<Genre> * ;
  <http://dbpedia.org/ontology/illustrator> @<Person> * ;
  <http://dbpedia.org/ontology/imageSize> xsd:integer ? ;
  <http://dbpedia.org/ontology/imdbId> xsd:string ? ;
  <http://dbpedia.org/ontology/impactFactor> xsd:double ? ;
  <http://dbpedia.org/ontology/isbn> xsd:string ;
  <http://dbpedia.org/ontology/issn> xsd:string ;
  <http://dbpedia.org/ontology/jstor> xsd:string ? ;
  <http://dbpedia.org/ontology/language> @<Language> + ;
  <http://dbpedia.org/ontology/lastPublicationDate> xsd:date ? ;
  <http://dbpedia.org/ontology/lcc> xsd:string ? ;
  <http://dbpedia.org/ontology/lccn> xsd:string ? ;
  <http://dbpedia.org/ontology/location> @<Place> * ;
  <http://dbpedia.org/ontology/logo> xsd:string ? ;
  <http://dbpedia.org/ontology/magazine> @<Magazine> ? ;
  <http://dbpedia.org/ontology/numberOfPages> xsd:positiveInteger * ;
  <http://dbpedia.org/ontology/numberOfVolumes> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/oclc> xsd:string ? ;
  <http://dbpedia.org/ontology/openAccessContent> xsd:string + ;
  <http://dbpedia.org/ontology/originalLanguage> @<Language> ? ;
  <http://dbpedia.org/ontology/owner> @<Agent> * ;
  <http://dbpedia.org/ontology/premiereDate> xsd:date ? ;
  <http://dbpedia.org/ontology/premiereYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/previousEditor> @<Person> * ;
  <http://dbpedia.org/ontology/previousWork> @<Work> * ;
  <http://dbpedia.org/ontology/publicationDate> xsd:date ;
  <http://dbpedia.org/ontology/publisher> @<Agent> + ;
  <http://dbpedia.org/ontology/releaseDate> xsd:date ? ;
  <http://dbpedia.org/ontology/settingOfPlay> xsd:string ? ;
  <http://dbpedia.org/ontology/sisterNewspaper> @<Newspaper> * ;
  <http://dbpedia.org/ontology/subjectOfPlay> xsd:string * ;
  <http://dbpedia.org/ontology/subsequentWork> @<Work> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/translator> @<Person> * ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/writer> @<Person> + ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> +
}

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<City> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/City> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<Genre> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Genre> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Language> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Language> ]
}

<Magazine> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Magazine> ]
}

<Newspaper> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Newspaper> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<Work> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Work> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
