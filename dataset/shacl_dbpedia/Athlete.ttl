@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


# ── Reusable value shapes (from SPARQL-inferred ranges) ──────────────────────

shapes:careerPrizeMoneyValueShape
    a sh:NodeShape ;
    sh:or (
        [ sh:datatype dbt:usDollar ]
        [ sh:datatype dbt:poundSterling ]
    ) .


<http://shaclshapes.org/AthleteShape> a sh:NodeShape ;
    sh:targetClass dbo:Athlete ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    # === Career & achievements ===
    sh:property [
        sh:path dbo:award ;
        sh:class dbo:Award ;
    ] ;

    sh:property [
        sh:path dbo:careerStation ;
        sh:class dbo:CareerStation ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:nationality ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:genre ;
        sh:class dbo:Genre ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:occupation ;
        sh:class dbo:PersonFunction ;
    ] ;

    sh:property [
        sh:path dbo:position ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:birthDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:undraftedYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartYear ;
        sh:datatype xsd:gYear ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:draftYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:birthYear ;
        sh:datatype xsd:gYear ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path dbo:number ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:title ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:birthName ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:stateOfOrigin ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:birthPlace ;
        sh:class dbo:Place ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathPlace ;
        sh:class dbo:Place ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:residence ;
        sh:class dbo:Place ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:hometown ;
        sh:class dbo:Settlement ;
        sh:maxCount 1 ;
    ] ;

    # === Media & publications ===
    sh:property [
        sh:path dbo:language ;
        sh:class dbo:Language ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageDisambiguates ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:college ;
        sh:class dbo:EducationalInstitution ;
    ] ;

    sh:property [
        sh:path dbo:school ;
        sh:class dbo:EducationalInstitution ;
    ] ;

    sh:property [
        sh:path dbo:university ;
        sh:class dbo:EducationalInstitution ;
    ] ;

    sh:property [
        sh:path dbo:highschool ;
        sh:class dbo:School ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:formerPartner ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:currentPartner ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:relative ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:manager ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:trainer ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:formerCoach ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:coach ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:choreographer ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:formerChoreographer ;
        sh:class dbo:Person ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path <http://dbpedia.org/ontology/Person/height> ;
        sh:datatype dbt:centimetre ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/Person/weight> ;
        sh:datatype dbt:kilogram ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:height ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:weight ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === References & links ===
    sh:property [
        sh:path dbo:bbr ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:imdbId ;
        sh:datatype xsd:string ;
    ] ;

    # === Sport & competitions ===
    sh:property [
        sh:path dbo:firstRace ;
        sh:class dbo:GrandPrix ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:lastRace ;
        sh:class dbo:GrandPrix ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:whaDraftTeam ;
        sh:class dbo:HockeyTeam ;
    ] ;

    sh:property [
        sh:path dbo:raceHorse ;
        sh:class dbo:Horse ;
    ] ;

    sh:property [
        sh:path dbo:ground ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:billed ;
        sh:class dbo:PopulatedPlace ;
    ] ;

    sh:property [
        sh:path dbo:race ;
        sh:class dbo:Race ;
    ] ;

    sh:property [
        sh:path dbo:sport ;
        sh:class dbo:Sport ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:league ;
        sh:class dbo:SportsLeague ;
    ] ;

    sh:property [
        sh:path dbo:prospectLeague ;
        sh:class dbo:SportsLeague ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:team ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:formerTeam ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:debutTeam ;
        sh:class dbo:SportsTeam ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:draftTeam ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:club ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:managerClub ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:nationalTeam ;
        sh:class dbo:SportsTeam ;
    ] ;

    sh:property [
        sh:path dbo:careerPrizeMoney ;
        sh:node shapes:careerPrizeMoneyValueShape ;
    ] ;

    sh:property [
        sh:path dbo:poles ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wins ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:championships ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:races ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:podiums ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:fastestLap ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:draftPick ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:battingSide ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:draftRound ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:shoots ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:bowlingSide ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:draft ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:plays ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:overallRecord ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:draftLeague ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:spike ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:block ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:whaDraft ;
        sh:datatype xsd:string ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:status ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

