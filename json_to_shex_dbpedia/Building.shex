PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<Building>

<Building> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Building> ] ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/activeYearsStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/address> rdf:langString + ;
  <http://dbpedia.org/ontology/alternativeName> rdf:langString * ;
  <http://dbpedia.org/ontology/architect> @<Architect> + ;
  <http://dbpedia.org/ontology/area> xsd:double ? ;
  <http://dbpedia.org/ontology/award> @<Award> * ;
  <http://dbpedia.org/ontology/bedCount> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/buildingEndDate> xsd:string ;
  <http://dbpedia.org/ontology/buildingStartDate> xsd:string ;
  <http://dbpedia.org/ontology/chain> @<Company> ? ;
  <http://dbpedia.org/ontology/city> @<City> + ;
  <http://dbpedia.org/ontology/classification> xsd:string * ;
  <http://dbpedia.org/ontology/closingDate> xsd:date ? ;
  <http://dbpedia.org/ontology/code> xsd:string ? ;
  <http://dbpedia.org/ontology/collection> xsd:string * ;
  <http://dbpedia.org/ontology/completionDate> xsd:date ? ;
  <http://dbpedia.org/ontology/cost> @<http://shaclshapes.org/costValueShape> * ;
  <http://dbpedia.org/ontology/country> @<Country> ;
  <http://dbpedia.org/ontology/cuisine> xsd:string * ;
  <http://dbpedia.org/ontology/currentlyUsedFor> xsd:string * ;
  <http://dbpedia.org/ontology/developer> @<Agent> * ;
  <http://dbpedia.org/ontology/elevatorCount> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/floorArea> xsd:positiveInteger ;
  <http://dbpedia.org/ontology/floorCount> xsd:positiveInteger ;
  <http://dbpedia.org/ontology/formerName> rdf:langString * ;
  <http://dbpedia.org/ontology/foundingDate> xsd:date ;
  <http://dbpedia.org/ontology/foundingYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/genre> @<Genre> * ;
  <http://dbpedia.org/ontology/governingBody> @<Organisation> ? ;
  <http://dbpedia.org/ontology/height> xsd:double ;
  <http://dbpedia.org/ontology/highschool> @<School> ? ;
  <http://dbpedia.org/ontology/isPartOf> . ? ;
  <http://dbpedia.org/ontology/location> @<Place> ;
  <http://dbpedia.org/ontology/nearestCity> @<PopulatedPlace> * ;
  <http://dbpedia.org/ontology/nrhpReferenceNumber> xsd:string ? ;
  <http://dbpedia.org/ontology/numberOfParkingSpaces> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/numberOfRestaurants> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/numberOfRooms> xsd:nonNegativeInteger + ;
  <http://dbpedia.org/ontology/numberOfSuites> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/numberOfVisitors> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/openingDate> xsd:date * ;
  <http://dbpedia.org/ontology/originalName> rdf:langString * ;
  <http://dbpedia.org/ontology/owner> @<Agent> * ;
  <http://dbpedia.org/ontology/position> . ;
  <http://dbpedia.org/ontology/seatingCapacity> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/status> xsd:string * ;
  <http://dbpedia.org/ontology/tenant> @<Organisation> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/width> xsd:double ? ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/yearOfConstruction> xsd:gYear ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI *
}

