        [ sh:datatype xsd:positiveInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/floorCount> ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
