            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/location> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path <http://dbpedia.org/ontology/numberOfVisitors> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/completionDate> ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/position> ],
        [ sh:class skos:Concept ;
