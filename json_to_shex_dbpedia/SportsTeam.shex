PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<SportsTeam>

<SportsTeam> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsTeam> ] ;
  <http://dbpedia.org/ontology/Work/runtime> <http://dbpedia.org/datatype/minute> * ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/activeYearsEndYear> xsd:date ? ;
  <http://dbpedia.org/ontology/aircraftTrainer> @<MeanOfTransportation> * ;
  <http://dbpedia.org/ontology/capacity> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/chairman> @<Person> * ;
  <http://dbpedia.org/ontology/chairmanTitle> rdf:langString ? ;
  <http://dbpedia.org/ontology/city> @<City> ;
  <http://dbpedia.org/ontology/coach> @<Person> + ;
  <http://dbpedia.org/ontology/colour> @<Colour> * ;
  <http://dbpedia.org/ontology/colourName> rdf:langString * ;
  <http://dbpedia.org/ontology/commandStructure> @<MilitaryUnit> ;
  <http://dbpedia.org/ontology/country> @<Country> ? ;
  <http://dbpedia.org/ontology/currentMember> @<Person> * ;
  <http://dbpedia.org/ontology/director> @<Person> * ;
  <http://dbpedia.org/ontology/dissolutionYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/dissolved> xsd:date ? ;
  <http://dbpedia.org/ontology/formationDate> xsd:date ? ;
  <http://dbpedia.org/ontology/foundingYear> xsd:gYear ;
  <http://dbpedia.org/ontology/generalManager> @<Person> * ;
  <http://dbpedia.org/ontology/homeStadium> @<Stadium> * ;
  <http://dbpedia.org/ontology/imdbId> xsd:string * ;
  <http://dbpedia.org/ontology/league> @<SportsLeague> + ;
  <http://dbpedia.org/ontology/location> @<Place> ;
  <http://dbpedia.org/ontology/logo> xsd:string + ;
  <http://dbpedia.org/ontology/manager> @<Person> + ;
  <http://dbpedia.org/ontology/managerTitle> xsd:string * ;
  <http://dbpedia.org/ontology/mascot> xsd:string * ;
  <http://dbpedia.org/ontology/owner> @<Agent> * ;
  <http://dbpedia.org/ontology/parentCompany> @<Company> * ;
  <http://dbpedia.org/ontology/president> @<Person> * ;
  <http://dbpedia.org/ontology/runtime> xsd:double ? ;
  <http://dbpedia.org/ontology/sport> @<Sport> ;
  <http://dbpedia.org/ontology/squadNumber> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/stadium> @<Stadium> + ;
  <http://dbpedia.org/ontology/status> xsd:string * ;
  <http://dbpedia.org/ontology/team> @<SportsTeam_class> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/title> rdf:langString * ;
  <http://dbpedia.org/ontology/uciCode> xsd:string ? ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI *
}

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<City> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/City> ]
}

<Colour> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Colour> ]
}

<Company> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Company> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<MeanOfTransportation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MeanOfTransportation> ]
}

<MilitaryUnit> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MilitaryUnit> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<Sport> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Sport> ]
}

<SportsLeague> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsLeague> ]
}

<SportsTeam_class> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsTeam> ]
}

<Stadium> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Stadium> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
