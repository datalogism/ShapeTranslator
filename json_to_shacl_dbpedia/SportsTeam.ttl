            sh:path <http://dbpedia.org/ontology/capacity> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/manager> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/currentMember> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:class <http://dbpedia.org/ontology/Company> ;
            sh:path <http://dbpedia.org/ontology/parentCompany> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/managerTitle> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/chairman> ],
        [ sh:class <http://dbpedia.org/ontology/Stadium> ;
            sh:path <http://dbpedia.org/ontology/homeStadium> ],
        [ sh:class <http://dbpedia.org/ontology/Stadium> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/stadium> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/mascot> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/foundingYear> ],
        [ sh:class <http://dbpedia.org/ontology/Sport> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/sport> ],
        [ sh:class <http://dbpedia.org/ontology/SportsTeam> ;
            sh:path <http://dbpedia.org/ontology/team> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/dissolved> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/coach> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/status> ],
        [ sh:class <http://dbpedia.org/ontology/MilitaryUnit> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/commandStructure> ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/country> ],
