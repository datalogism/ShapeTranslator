@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/CityShape> a sh:NodeShape ;
    sh:targetClass dbo:City ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Career & achievements ===
    sh:property [
        sh:path dbo:saint ;
        sh:class dbo:Saint ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:foundingDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path dbo:populationMetro ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaTotal ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationTotal ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaLand ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaWater ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:populationUrban ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationTotalRanking ;
        sh:datatype xsd:positiveInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationAsOf ;
        sh:datatype xsd:date ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> ;
        sh:datatype dbt:squareKilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaMetro ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:area ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/PopulatedPlace/area> ;
        sh:datatype dbt:squareKilometre ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:demonym ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:originalName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:motto ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:synonym ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path <http://purl.org/linguistics/gold/hypernym> ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:utcOffset ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:postalCode ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaCode ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:district ;
        sh:class dbo:PopulatedPlace ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:federalState ;
        sh:class dbo:PopulatedPlace ;
        sh:maxCount 1 ;
    ] ;

    # === Media & publications ===
    sh:property [
        sh:path dbo:wikiPageDisambiguates ;
        sh:maxCount 1 ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path dbo:populationDensity ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:elevation ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationDensity> ;
        sh:datatype dbt:inhabitantsPerSquareKilometre ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:maximumElevation ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationMetroDensity ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    # === Politics & governance ===
    sh:property [
        sh:path dbo:leaderTitle ;
        sh:datatype rdf:langString ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:politicalLeader ;
        sh:class dbo:PersonFunction ;
    ] ;

    sh:property [
        sh:path dbo:governingBody ;
        sh:class dbo:Organisation ;
    ] ;

    sh:property [
        sh:path dbo:leaderName ;
        sh:class dbo:Person ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:mayor ;
        sh:class dbo:Mayor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === References & links ===
    sh:property [
        sh:path skos:exactMatch ;
    ] ;

    sh:property [
        sh:path dbo:predecessor ;
        sh:maxCount 1 ;
    ] ;

    # === Sport & competitions ===
    sh:property [
        sh:path dbo:team ;
        sh:class dbo:SportsTeam ;
    ] ;

    # === Economics & statistics (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> ;
                sh:datatype dbt:squareKilometre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:populationDensity ;
                sh:datatype dbt:squareKilometre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:percentageOfAreaWater ;
                sh:datatype xsd:float ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaUrban ;
                sh:datatype xsd:float ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:areaUrban ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaMetro ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaUrban> ;
                sh:datatype dbt:squareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> ;
                sh:datatype dbt:squareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:licenceNumber ;
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:populationMetroDensity ;
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # === Location & geography (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:country ;
                sh:class dbo:Country ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaTotal ;
                sh:class dbo:Country ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:isoCodeRegion ;
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaUrban> ;
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # === People & family (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:founder ;
                sh:class dbo:Person ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:area ;
                sh:class dbo:Person ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # === Physical dimensions & specs (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:minimumElevation ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/area> ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationMetroDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationMetroDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:populationUrbanDensity ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationUrbanDensity> ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationUrbanDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:populationUrbanDensity ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # === Politics & governance (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:governmentType ;
                sh:class dbo:GovernmentType ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> ;
                sh:class dbo:GovernmentType ;
                sh:minCount 1 ;
            ]
        ]
    ) .

