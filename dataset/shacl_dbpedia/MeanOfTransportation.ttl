@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


# ── Reusable value shapes (from SPARQL-inferred ranges) ──────────────────────

shapes:costValueShape
    a sh:NodeShape ;
    sh:or (
        [ sh:datatype dbt:usDollar ]
        [ sh:datatype dbt:poundSterling ]
        [ sh:datatype dbt:euro ]
        [ sh:datatype dbt:japaneseYen ]
        [ sh:datatype dbt:canadianDollar ]
        [ sh:datatype dbt:swedishKrona ]
        [ sh:datatype dbt:norwegianKrone ]
        [ sh:datatype dbt:danishKrone ]
        [ sh:datatype dbt:swissFranc ]
        [ sh:datatype dbt:australianDollar ]
        [ sh:datatype dbt:malaysianRinggit ]
        [ sh:datatype dbt:russianRouble ]
        [ sh:datatype dbt:indonesianRupiah ]
        [ sh:datatype dbt:polishZłoty ]
        [ sh:datatype dbt:unitedArabEmiratesDirham ]
        [ sh:datatype dbt:renminbi ]
        [ sh:datatype dbt:czechKoruna ]
        [ sh:datatype dbt:indianRupee ]
        [ sh:datatype dbt:bulgarianLev ]
        [ sh:datatype dbt:sriLankanRupee ]
        [ sh:datatype dbt:hungarianForint ]
        [ sh:datatype dbt:southKoreanWon ]
        [ sh:datatype dbt:lithuanianLitas ]
        [ sh:datatype dbt:croatianKuna ]
        [ sh:datatype dbt:iraqiDinar ]
        [ sh:datatype dbt:mexicanPeso ]
        [ sh:datatype dbt:saudiRiyal ]
        [ sh:datatype dbt:turkishLira ]
        [ sh:datatype dbt:estonianKroon ]
        [ sh:datatype dbt:hongKongDollar ]
        [ sh:datatype dbt:newTaiwanDollar ]
        [ sh:datatype dbt:thaiBaht ]
        [ sh:datatype dbt:pakistaniRupee ]
        [ sh:datatype dbt:slovakKoruna ]
        [ sh:datatype dbt:chileanPeso ]
        [ sh:datatype dbt:kuwaitiDinar ]
        [ sh:datatype dbt:newZealandDollar ]
        [ sh:datatype dbt:bangladeshiTaka ]
        [ sh:datatype dbt:philippinePeso ]
        [ sh:datatype dbt:serbianDinar ]
        [ sh:datatype dbt:brazilianReal ]
        [ sh:datatype dbt:tanzanianShilling ]
        [ sh:datatype dbt:georgianLari ]
        [ sh:datatype dbt:algerianDinar ]
        [ sh:datatype dbt:armenianDram ]
        [ sh:datatype dbt:colombianPeso ]
        [ sh:datatype dbt:argentinePeso ]
        [ sh:datatype dbt:israeliNewSheqel ]
        [ sh:datatype dbt:moroccanDirham ]
        [ sh:datatype dbt:egyptianPound ]
        [ sh:datatype dbt:lebanesePound ]
        [ sh:datatype dbt:iranianRial ]
        [ sh:datatype dbt:capeVerdeEscudo ]
        [ sh:datatype dbt:kenyanShilling ]
        [ sh:datatype dbt:ugandaShilling ]
        [ sh:datatype dbt:bruneiDollar ]
        [ sh:datatype dbt:cambodianRiel ]
    ) .

shapes:unitCostValueShape
    a sh:NodeShape ;
    sh:or (
        [ sh:datatype dbt:usDollar ]
        [ sh:datatype dbt:euro ]
        [ sh:datatype dbt:poundSterling ]
        [ sh:datatype dbt:russianRouble ]
        [ sh:datatype dbt:nicaraguanCórdoba ]
    ) .


<http://shaclshapes.org/MeanOfTransportationShape> a sh:NodeShape ;
    sh:targetClass dbo:MeanOfTransportation ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:launchSite ;
        sh:class dbo:Building ;
    ] ;

    sh:property [
        sh:path dbo:shipLaunch ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:commissioningDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:layingDown ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:decommissioningDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:acquirementDate ;
        sh:datatype xsd:date ;
    ] ;

    sh:property [
        sh:path dbo:orderDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:completionDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:maidenVoyage ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:recommissioningDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:captureDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:maidenFlight ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:retired ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:finalFlight ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:productionStartYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:productionEndYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:modelStartYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:modelEndYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:yearOfConstruction ;
        sh:datatype xsd:gYear ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path dbo:numberBuilt ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:cylinderCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:totalLaunches ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:failedLaunches ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:numberOfDoors ;
        sh:datatype xsd:positiveInteger ;
    ] ;

    sh:property [
        sh:path dbo:cost ;
        sh:node shapes:costValueShape ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:unitCost ;
        sh:node shapes:unitCostValueShape ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:alternativeName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:motto ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
    ] ;

    sh:property [
        sh:path dbo:countryOrigin ;
        sh:class dbo:Country ;
    ] ;

    sh:property [
        sh:path dbo:homeport ;
        sh:class dbo:Place ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:origin ;
        sh:class dbo:PopulatedPlace ;
        sh:maxCount 1 ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:designCompany ;
        sh:class dbo:Company ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
    ] ;

    sh:property [
        sh:path dbo:designer ;
        sh:class dbo:Person ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path dbo:engine ;
        sh:class dbo:AutomobileEngine ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:battery ;
        sh:class dbo:Battery ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:shipBeam ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:topSpeed ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:shipDraft ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:shipDisplacement ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:diameter ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:capacity ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    # === References & links ===
    sh:property [
        sh:path dbo:relatedMeanOfTransportation ;
        sh:class dbo:MeanOfTransportation ;
    ] ;

    sh:property [
        sh:path dbo:comparable ;
        sh:class dbo:Rocket ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:automobilePlatform ;
        sh:class dbo:Automobile ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:rocketStages ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:status ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:transmission ;
        sh:datatype xsd:string ;
    ] ;

    # === Physical dimensions & specs (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/length> ;
                sh:datatype dbt:millimetre ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:length ;
                sh:datatype dbt:millimetre ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/height> ;
                sh:datatype dbt:millimetre ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:height ;
                sh:datatype dbt:millimetre ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/width> ;
                sh:datatype dbt:millimetre ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:width ;
                sh:datatype dbt:millimetre ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Automobile/wheelbase> ;
                sh:datatype dbt:millimetre ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:wheelbase ;
                sh:datatype dbt:millimetre ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:length ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/length> ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:height ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/height> ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:width ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/width> ;
                sh:datatype xsd:double ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:wheelbase ;
                sh:datatype xsd:double ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Automobile/wheelbase> ;
                sh:datatype xsd:double ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:weight ;
                sh:datatype xsd:double ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/weight> ;
                sh:datatype xsd:double ;
            ]
        ]
    ) .

