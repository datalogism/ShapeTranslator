@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/ComicsCharacterShape> a sh:NodeShape ;
    sh:targetClass dbo:ComicsCharacter ;

    # ═══════════════════════════════════════════════════════════════════════════
    # IDENTITY & NAMING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path rdfs:label ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:name ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:givenName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DESCRIPTION & ABSTRACT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:abstract ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # FIRST APPEARANCE & TIMELINE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:firstAppearance ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # CREATORS & WRITERS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:creator ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:writer ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:portrayer ;
        sh:class dbo:Person ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # PUBLISHER & AFFILIATION
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:publisher ;
        sh:class dbo:Agent ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # MEDIA & IMAGES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EXTERNAL REFERENCES & LINKS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:imdbId ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # WIKIPEDIA & DBPEDIA METADATA
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageDisambiguates ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] .
