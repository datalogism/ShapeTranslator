@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/CityShape> a sh:NodeShape ;
    sh:targetClass dbo:City ;

    # ═══════════════════════════════════════════════════════════════════════════
    # IDENTITY & NAMING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path rdfs:label ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:name ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:nick ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:originalName ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:demonym ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:motto ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:synonym ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DESCRIPTION & ABSTRACT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:abstract ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DATES & TIMELINE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:foundingDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:founder ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # LOCATION & GEOGRAPHY
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:district ;
        sh:class dbo:PopulatedPlace ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:federalState ;
        sh:class dbo:PopulatedPlace ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:subdivision ;
        sh:class dbo:AdministrativeRegion ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:isoCodeRegion ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:postalCode ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaCode ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:licenceNumber ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # GEOSPATIAL COORDINATES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path geo:lat ;
        sh:datatype xsd:float ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path geo:long ;
        sh:datatype xsd:float ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path geo:geometry ;
        sh:datatype geosparql:wktLiteral ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # TIME ZONE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:timeZone ;
        sh:node shapes:TimeZoneShape ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:utcOffset ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # ELEVATION & TOPOGRAPHY
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:elevation ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:minimumElevation ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:maximumElevation ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # AREA MEASUREMENTS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:areaTotal ;
        sh:or (
            [ sh:datatype xsd:double ]
            [ sh:datatype dbt:squareKilometre ]
        ) ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaLand ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaWater ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:percentageOfAreaWater ;
        sh:datatype xsd:float ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> ;
        sh:datatype dbt:squareKilometre ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaMetro ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # --- Area Total (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> ;
                sh:datatype dbt:squareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaTotal ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- Area Urban (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaUrban> ;
                sh:datatype dbt:squareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaUrban ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- Area Metro (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> ;
                sh:datatype dbt:squareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:areaMetro ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- Area (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:area ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/area> ;
                sh:datatype dbt:squareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # POPULATION STATISTICS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:populationTotal ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationUrban ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationMetro ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:populationAsOf ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
    ] ;

    # --- Population Density (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:populationDensity ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    # --- Population Metro Density (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationMetroDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:populationMetroDensity ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- Population Urban Density (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:populationUrbanDensity ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationUrbanDensity> ;
                sh:datatype dbt:inhabitantsPerSquareKilometre ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # POLITICS & GOVERNANCE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:governmentType ;
        sh:class dbo:GovernmentType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:governingBody ;
        sh:class dbo:Legislature ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:mayor ;
        sh:class dbo:Mayor ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:leaderName ;
        sh:class dbo:Person ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:leaderTitle ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:leaderParty ;
        sh:class dbo:PoliticalParty ;
    ] ;

    sh:property [
        sh:path dbo:politicalLeader ;
        sh:class dbo:PoliticalFunction ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # CULTURAL & RELIGIOUS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:saint ;
        sh:class dbo:Saint ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:namedAfter ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SPORTS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:team ;
        sh:class dbo:SportsTeam ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # MEDIA & IMAGES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EXTERNAL REFERENCES & LINKS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path foaf:homepage ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path skos:exactMatch ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # WIKIPEDIA & DBPEDIA METADATA
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageDisambiguates ;
        sh:maxCount 1 ;
    ] .


# ═══════════════════════════════════════════════════════════════════════════════
# REUSABLE VALUE SHAPES
# ═══════════════════════════════════════════════════════════════════════════════

shapes:TimeZoneShape a sh:NodeShape ;
    sh:in (
        dbr:Eastern_Time_Zone
        dbr:Indian_Standard_Time
        dbr:East_Africa_Time
        dbr:Iran_Standard_Time
        dbr:Time_in_Madagascar
        dbr:UTC%2B03:00
        dbr:Central_Time_Zone
        dbr:Pakistan_Standard_Time
        dbr:Mountain_Time_Zone
        dbr:Eastern_European_Summer_Time
        dbr:Eastern_European_Time
        dbr:Time_in_Malaysia
        dbr:Sri_Lanka_Standard_Time
        dbr:Central_European_Summer_Time
        dbr:Central_European_Time
        dbr:Central_Africa_Time
        dbr:South_Africa_Standard_Time
        dbr:Myanmar_Standard_Time
        dbr:Time_in_the_Republic_of_Ireland
