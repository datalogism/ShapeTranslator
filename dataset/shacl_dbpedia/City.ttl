        dbr:UTC%2B11:00
        dbr:Greenwich_Mean_Time
        dbr:Coordinated_Universal_Time
        dbr:West_Africa_Time
        dbr:Pacific_Time_Zone
        dbr:Time_in_Indonesia
        dbr:Time_in_Pakistan
        dbr:Azerbaijan_Time
        dbr:Saudi_Arabia_Standard_Time
