PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<City>

<City> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/City> ] ;
  <http://dbpedia.org/ontology/PopulatedPlace/area> <http://dbpedia.org/datatype/squareKilometre> ? ;
  <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> <http://dbpedia.org/datatype/squareKilometre> ? ;
  <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> <http://dbpedia.org/datatype/squareKilometre> ;
  <http://dbpedia.org/ontology/PopulatedPlace/populationDensity> <http://dbpedia.org/datatype/inhabitantsPerSquareKilometre> + ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/area> xsd:double ? ;
  <http://dbpedia.org/ontology/areaCode> xsd:string ;
  <http://dbpedia.org/ontology/areaLand> xsd:double + ;
  <http://dbpedia.org/ontology/areaMetro> xsd:double ? ;
  <http://dbpedia.org/ontology/areaTotal> xsd:double ;
  <http://dbpedia.org/ontology/areaWater> xsd:double * ;
  <http://dbpedia.org/ontology/demonym> rdf:langString * ;
  <http://dbpedia.org/ontology/district> @<PopulatedPlace> ? ;
  <http://dbpedia.org/ontology/elevation> xsd:double ;
  <http://dbpedia.org/ontology/federalState> @<PopulatedPlace> ? ;
  <http://dbpedia.org/ontology/foundingDate> xsd:date ;
  <http://dbpedia.org/ontology/governingBody> @<Organisation> * ;
  <http://dbpedia.org/ontology/leaderName> @<Person> ? ;
  <http://dbpedia.org/ontology/leaderTitle> rdf:langString ? ;
  <http://dbpedia.org/ontology/location> @<Place> ? ;
  <http://dbpedia.org/ontology/maximumElevation> xsd:double ? ;
  <http://dbpedia.org/ontology/mayor> @<Mayor> ;
  <http://dbpedia.org/ontology/motto> xsd:string * ;
  <http://dbpedia.org/ontology/originalName> rdf:langString * ;
  <http://dbpedia.org/ontology/politicalLeader> @<PersonFunction> * ;
  <http://dbpedia.org/ontology/populationAsOf> xsd:date * ;
  <http://dbpedia.org/ontology/populationDensity> xsd:double + ;
  <http://dbpedia.org/ontology/populationDensity> <http://dbpedia.org/datatype/squareKilometre> ;
  <http://dbpedia.org/ontology/populationMetro> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/populationMetroDensity> xsd:double ? ;
  <http://dbpedia.org/ontology/populationTotal> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/populationTotalRanking> xsd:positiveInteger ? ;
  <http://dbpedia.org/ontology/populationUrban> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/postalCode> xsd:string ;
  <http://dbpedia.org/ontology/predecessor> . ? ;
  <http://dbpedia.org/ontology/saint> @<Saint> * ;
  <http://dbpedia.org/ontology/synonym> xsd:string * ;
  <http://dbpedia.org/ontology/team> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/utcOffset> xsd:string ;
  <http://dbpedia.org/ontology/wikiPageDisambiguates> . ? ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  <http://purl.org/linguistics/gold/hypernym> . ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  skos:exactMatch . * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI *
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Mayor> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Mayor> ]
}

<Organisation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Organisation> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<PersonFunction> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PersonFunction> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PopulatedPlace> ]
}

<Saint> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Saint> ]
}

<SportsTeam> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsTeam> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
