@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/FoodShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/protein> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:path <http://dbpedia.org/ontology/region> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/year> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/distributor> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/servingTemperature> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:path <http://dbpedia.org/ontology/location> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/iupacName> ],
        [ sh:class <http://dbpedia.org/ontology/Company> ;
            sh:path <http://dbpedia.org/ontology/owningCompany> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/foundingYear> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:path <http://dbpedia.org/ontology/owner> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/cuisine> ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:hasValue <http://dbpedia.org/ontology/Food> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/manufacturer> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:path <http://dbpedia.org/ontology/country> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/ingredientName> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/alias> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:path <http://dbpedia.org/ontology/origin> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Species> ;
            sh:path <http://dbpedia.org/ontology/species> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/approximateCalories> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/servingSize> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/notes> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/keyPerson> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:path <http://dbpedia.org/ontology/regionServed> ] ;
    sh:targetClass <http://dbpedia.org/ontology/Food> .

