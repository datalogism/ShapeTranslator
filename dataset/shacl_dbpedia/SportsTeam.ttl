@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/SportsTeamShape> a sh:NodeShape ;
    sh:targetClass dbo:SportsTeam ;

    # ═══════════════════════════════════════════════════════════════════════════
    # IDENTITY & NAMING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path rdfs:label ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:title ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path foaf:nick ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:mascot ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:uciCode ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # --- Team Name (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:teamName ;
                sh:nodeKind sh:Literal ;
                sh:datatype rdf:langString ;
            ]
        ]
        [
            sh:property [
                sh:path foaf:name ;
                sh:nodeKind sh:Literal ;
                sh:datatype rdf:langString ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # TEAM COLORS & BRANDING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:colour ;
        sh:class dbo:Colour ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:colourName ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:logo ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DESCRIPTION & ABSTRACT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:abstract ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DATES & TIMELINE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:formationDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:foundingYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:dissolutionYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # --- Dissolved/ActiveYearsEnd Date (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:dissolved ;
                sh:datatype xsd:date ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:activeYearsEndYear ;
                sh:datatype xsd:date ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- ActiveYearsStart/FoundingYear (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:activeYearsStartYear ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingYear ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- ActiveYearsEnd/Dissolved gYear (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:activeYearsEndYear ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:dissolved ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # --- StartYear/FoundingYear (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:startYear ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingYear ;
                sh:datatype xsd:gYear ;
                sh:nodeKind sh:Literal ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # LOCATION & GEOGRAPHY
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:city ;
        sh:class dbo:City ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # --- LocationCity/Location (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:locationCity ;
                sh:class dbo:City ;
                sh:nodeKind sh:IRI ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:location ;
                sh:class dbo:Place ;
                sh:nodeKind sh:IRI ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SPORT & LEAGUE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:sport ;
        sh:class dbo:Sport ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:league ;
        sh:class dbo:SportsLeague ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:status ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # STADIUM & VENUE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path [ sh:alternativePath ( dbo:stadium dbo:homeStadium ) ] ;
        sh:class dbo:Stadium ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:ground ;
        sh:nodeKind sh:IRI ;
        sh:or (
            [ sh:class geo:SpatialThing ]
            [ sh:class dbo:Place ]
        ) ;
    ] ;

    sh:property [
        sh:path dbo:capacity ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SQUAD & MEMBERS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:currentMember ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:squadNumber ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # COACHING & MANAGEMENT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:coach ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:manager ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:generalManager ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:managerTitle ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:director ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # OWNERSHIP & GOVERNANCE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:chairman ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:chairmanTitle ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:president ;
        sh:class dbo:Person ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:parentCompany ;
        sh:class dbo:Company ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SUCCESSOR & PREDECESSOR TEAMS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:successor ;
        sh:class dbo:SportsTeam ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:predecessor ;
        sh:class dbo:SportsTeam ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # RUNTIME (for broadcasts/media)
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path <http://dbpedia.org/ontology/Work/runtime> ;
        sh:datatype dbt:minute ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:runtime ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # MEDIA & IMAGES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EXTERNAL REFERENCES & LINKS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path foaf:homepage ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:imdbId ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # WIKIPEDIA & DBPEDIA METADATA
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] .
