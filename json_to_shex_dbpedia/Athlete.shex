PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<Athlete>

<Athlete> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Athlete> ] ;
  <http://dbpedia.org/ontology/Person/height> <http://dbpedia.org/datatype/centimetre> ;
  <http://dbpedia.org/ontology/Person/weight> <http://dbpedia.org/datatype/kilogram> ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/activeYearsEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/activeYearsStartYear> xsd:gYear + ;
  <http://dbpedia.org/ontology/award> @<Award> * ;
  <http://dbpedia.org/ontology/battingSide> xsd:string * ;
  <http://dbpedia.org/ontology/bbr> xsd:string ? ;
  <http://dbpedia.org/ontology/billed> @<PopulatedPlace> * ;
  <http://dbpedia.org/ontology/birthDate> xsd:date ;
  <http://dbpedia.org/ontology/birthName> rdf:langString ;
  <http://dbpedia.org/ontology/birthPlace> @<Place> ;
  <http://dbpedia.org/ontology/birthYear> xsd:gYear ;
  <http://dbpedia.org/ontology/block> xsd:string * ;
  <http://dbpedia.org/ontology/bowlingSide> xsd:string * ;
  <http://dbpedia.org/ontology/careerPrizeMoney> @<http://shaclshapes.org/careerPrizeMoneyValueShape> * ;
  <http://dbpedia.org/ontology/careerStation> @<CareerStation> + ;
  <http://dbpedia.org/ontology/championships> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/choreographer> @<Person> * ;
  <http://dbpedia.org/ontology/club> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/coach> @<Person> * ;
  <http://dbpedia.org/ontology/college> @<EducationalInstitution> * ;
  <http://dbpedia.org/ontology/country> @<Country> + ;
  <http://dbpedia.org/ontology/currentPartner> @<Person> * ;
  <http://dbpedia.org/ontology/deathDate> xsd:date ? ;
  <http://dbpedia.org/ontology/deathPlace> @<Place> ? ;
  <http://dbpedia.org/ontology/debutTeam> @<SportsTeam> ? ;
  <http://dbpedia.org/ontology/draft> xsd:string * ;
  <http://dbpedia.org/ontology/draftLeague> xsd:string * ;
  <http://dbpedia.org/ontology/draftPick> xsd:string * ;
  <http://dbpedia.org/ontology/draftRound> xsd:string * ;
  <http://dbpedia.org/ontology/draftTeam> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/draftYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/fastestLap> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/firstRace> @<GrandPrix> ? ;
  <http://dbpedia.org/ontology/formerChoreographer> @<Person> * ;
  <http://dbpedia.org/ontology/formerCoach> @<Person> * ;
  <http://dbpedia.org/ontology/formerPartner> @<Person> * ;
  <http://dbpedia.org/ontology/formerTeam> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/genre> @<Genre> ;
  <http://dbpedia.org/ontology/ground> @<Place> * ;
  <http://dbpedia.org/ontology/height> xsd:double ;
  <http://dbpedia.org/ontology/highschool> @<School> * ;
  <http://dbpedia.org/ontology/hometown> @<Settlement> ? ;
  <http://dbpedia.org/ontology/imdbId> xsd:string * ;
  <http://dbpedia.org/ontology/language> @<Language> + ;
  <http://dbpedia.org/ontology/lastRace> @<GrandPrix> ? ;
  <http://dbpedia.org/ontology/league> @<SportsLeague> * ;
  <http://dbpedia.org/ontology/manager> @<Person> * ;
  <http://dbpedia.org/ontology/managerClub> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/nationalTeam> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/nationality> @<Country> + ;
  <http://dbpedia.org/ontology/number> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/occupation> @<PersonFunction> * ;
  <http://dbpedia.org/ontology/overallRecord> xsd:string * ;
  <http://dbpedia.org/ontology/plays> xsd:string * ;
  <http://dbpedia.org/ontology/podiums> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/poles> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/position> . * ;
  <http://dbpedia.org/ontology/prospectLeague> @<SportsLeague> ? ;
  <http://dbpedia.org/ontology/race> @<Race> * ;
  <http://dbpedia.org/ontology/raceHorse> @<Horse> * ;
  <http://dbpedia.org/ontology/races> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/relative> @<Person> * ;
  <http://dbpedia.org/ontology/residence> @<Place> ;
  <http://dbpedia.org/ontology/school> @<EducationalInstitution> * ;
  <http://dbpedia.org/ontology/shoots> xsd:string * ;
  <http://dbpedia.org/ontology/spike> xsd:string * ;
  <http://dbpedia.org/ontology/sport> @<Sport> + ;
  <http://dbpedia.org/ontology/stateOfOrigin> @<Country> + ;
  <http://dbpedia.org/ontology/status> xsd:string ;
  <http://dbpedia.org/ontology/team> @<SportsTeam> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/title> rdf:langString * ;
  <http://dbpedia.org/ontology/trainer> @<Person> * ;
  <http://dbpedia.org/ontology/undraftedYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/university> @<EducationalInstitution> * ;
  <http://dbpedia.org/ontology/weight> xsd:double ;
  <http://dbpedia.org/ontology/whaDraft> xsd:string * ;
  <http://dbpedia.org/ontology/whaDraftTeam> @<HockeyTeam> * ;
  <http://dbpedia.org/ontology/wikiPageDisambiguates> . * ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wins> xsd:nonNegativeInteger * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> +
}

<careerPrizeMoneyValue> <http://dbpedia.org/datatype/poundSterling> OR <http://dbpedia.org/datatype/usDollar>

<Award> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Award> ]
}

<CareerStation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/CareerStation> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<EducationalInstitution> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/EducationalInstitution> ]
}

<Genre> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Genre> ]
}

<GrandPrix> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/GrandPrix> ]
}

<HockeyTeam> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/HockeyTeam> ]
}

<Horse> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Horse> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Language> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Language> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<PersonFunction> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PersonFunction> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PopulatedPlace> ]
}

<Race> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Race> ]
}

<School> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/School> ]
}

<Settlement> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Settlement> ]
}

<Sport> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Sport> ]
}

<SportsLeague> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsLeague> ]
}

<SportsTeam> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/SportsTeam> ]
}
