PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<Airport>

<Airport> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Airport> ] ;
  <http://dbpedia.org/ontology/Infrastructure/length> <http://dbpedia.org/datatype/kilometre> ? ;
  <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> <http://dbpedia.org/datatype/squareKilometre> ? ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/agencyStationCode> xsd:string ? ;
  <http://dbpedia.org/ontology/area> xsd:double * ;
  <http://dbpedia.org/ontology/areaCode> xsd:string ? ;
  <http://dbpedia.org/ontology/areaLand> xsd:double ? ;
  <http://dbpedia.org/ontology/areaTotal> xsd:double ? ;
  <http://dbpedia.org/ontology/buildingEndDate> xsd:string ? ;
  <http://dbpedia.org/ontology/city> @<City> ;
  <http://dbpedia.org/ontology/commander> @<Person> * ;
  <http://dbpedia.org/ontology/country> @<Country> + ;
  <http://dbpedia.org/ontology/district> @<PopulatedPlace> ? ;
  <http://dbpedia.org/ontology/elevation> xsd:double ;
  <http://dbpedia.org/ontology/faaLocationIdentifier> xsd:string ? ;
  <http://dbpedia.org/ontology/foundingDate> xsd:date ? ;
  <http://dbpedia.org/ontology/foundingYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/gridReference> xsd:string ? ;
  <http://dbpedia.org/ontology/iataLocationIdentifier> xsd:string ;
  <http://dbpedia.org/ontology/icaoLocationIdentifier> xsd:string ;
  <http://dbpedia.org/ontology/locatedInArea> @<Place> * ;
  <http://dbpedia.org/ontology/location> @<Place> ;
  <http://dbpedia.org/ontology/locationIdentifier> xsd:string ? ;
  <http://dbpedia.org/ontology/nearestCity> @<PopulatedPlace> + ;
  <http://dbpedia.org/ontology/nrhpReferenceNumber> xsd:string ;
  <http://dbpedia.org/ontology/openingDate> xsd:date ? ;
  <http://dbpedia.org/ontology/openingYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/originalName> rdf:langString ? ;
  <http://dbpedia.org/ontology/owner> @<Agent> * ;
  <http://dbpedia.org/ontology/postalCode> xsd:string ;
  <http://dbpedia.org/ontology/principalArea> @<PopulatedPlace> ? ;
  <http://dbpedia.org/ontology/routeEnd> @<Station> {0,5} ;
  <http://dbpedia.org/ontology/routeEndDirection> xsd:string ;
  <http://dbpedia.org/ontology/routeJunction> @<Station> * ;
  <http://dbpedia.org/ontology/routeNumber> xsd:string ? ;
  <http://dbpedia.org/ontology/routeStart> @<Station> ;
  <http://dbpedia.org/ontology/routeStartDirection> xsd:string ? ;
  <http://dbpedia.org/ontology/routeTypeAbbreviation> xsd:string ? ;
  <http://dbpedia.org/ontology/runwayDesignation> xsd:string + ;
  <http://dbpedia.org/ontology/runwayLength> xsd:double + ;
  <http://dbpedia.org/ontology/runwaySurface> xsd:string + ;
  <http://dbpedia.org/ontology/utcOffset> xsd:string ? ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/yearOfConstruction> xsd:gYear ;
  rdf:type . + ;
  rdfs:label rdf:langString +
}

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<City> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/City> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PopulatedPlace> ]
}

<Station> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Station> ]
}
