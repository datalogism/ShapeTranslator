<unitCostValue> <http://dbpedia.org/datatype/euro> OR <http://dbpedia.org/datatype/nicaraguanCórdoba> OR <http://dbpedia.org/datatype/poundSterling> OR <http://dbpedia.org/datatype/russianRouble> OR <http://dbpedia.org/datatype/usDollar>

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<Automobile> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Automobile> ]
}

<AutomobileEngine> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/AutomobileEngine> ]
}

<Battery> EXTRA rdf:type {
