@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/MusicalWorkShape> a sh:NodeShape ;
    sh:property [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/artist> ],
        [ sh:class foaf:Document ;
            sh:maxCount 1 ;
            sh:path foaf:homepage ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:hasValue <http://dbpedia.org/ontology/MusicalWork> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/publicationDate> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/previousWork> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:class <http://dbpedia.org/ontology/MusicalArtist> ;
            sh:path <http://dbpedia.org/ontology/associatedMusicalArtist> ],
        [ sh:datatype rdf:langString ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/title> ],
        [ sh:class <http://dbpedia.org/ontology/Sound> ;
            sh:path <http://dbpedia.org/ontology/soundRecording> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:path <http://dbpedia.org/ontology/runtime> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:path <http://dbpedia.org/ontology/country> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:differentFrom ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/editing> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/distributor> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:class <http://dbpedia.org/ontology/Company> ;
            sh:path <http://dbpedia.org/ontology/productionCompany> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/lyrics> ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/subsequentWork> ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/basedOn> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:class <http://dbpedia.org/ontology/RecordLabel> ;
            sh:path <http://dbpedia.org/ontology/recordLabel> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:class <http://dbpedia.org/ontology/Album> ;
            sh:path <http://dbpedia.org/ontology/album> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:path <http://dbpedia.org/ontology/origin> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/writer> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/releaseDate> ],
        [ sh:datatype rdfs:Literal ;
            sh:path foaf:name ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/composer> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/author> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/subtitle> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:class <http://dbpedia.org/ontology/Band> ;
            sh:path <http://dbpedia.org/ontology/associatedBand> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/recordDate> ],
        [ sh:class <http://dbpedia.org/ontology/MusicalArtist> ;
            sh:path <http://dbpedia.org/ontology/musicComposer> ],
        [ sh:class <http://dbpedia.org/ontology/Award> ;
            sh:path <http://dbpedia.org/ontology/award> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:path <http://dbpedia.org/ontology/producer> ],
        [ sh:datatype <http://dbpedia.org/datatype/minute> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/Work/runtime> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/imdbId> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/director> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:path <http://dbpedia.org/ontology/recordedIn> ],
        [ sh:class <http://dbpedia.org/ontology/Language> ;
            sh:path <http://dbpedia.org/ontology/language> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/musicBy> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/cinematography> ],
        [ sh:maxCount 1 ;
            sh:node <http://shaclshapes.org/budgetValueShape> ;
            sh:path <http://dbpedia.org/ontology/budget> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/bSide> ],
        [ sh:class <http://dbpedia.org/ontology/Genre> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/genre> ],
        [ sh:class <http://dbpedia.org/ontology/Actor> ;
            sh:path <http://dbpedia.org/ontology/starring> ],
        [ sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageDisambiguates> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageInterLanguageLink> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/runtime> ] ;
    sh:targetClass <http://dbpedia.org/ontology/MusicalWork> .

<http://shaclshapes.org/budgetValueShape> a sh:NodeShape ;
    sh:or ( [ sh:datatype <http://dbpedia.org/datatype/canadianDollar> ] [ sh:datatype <http://dbpedia.org/datatype/croatianKuna> ] [ sh:datatype <http://dbpedia.org/datatype/danishKrone> ] [ sh:datatype <http://dbpedia.org/datatype/euro> ] [ sh:datatype <http://dbpedia.org/datatype/hungarianForint> ] [ sh:datatype <http://dbpedia.org/datatype/indianRupee> ] [ sh:datatype <http://dbpedia.org/datatype/japaneseYen> ] [ sh:datatype <http://dbpedia.org/datatype/jordanianDinar> ] [ sh:datatype <http://dbpedia.org/datatype/lebanesePound> ] [ sh:datatype <http://dbpedia.org/datatype/malaysianRinggit> ] [ sh:datatype <http://dbpedia.org/datatype/nepaleseRupee> ] [ sh:datatype <http://dbpedia.org/datatype/netherlandsAntilleanGuilder> ] [ sh:datatype <http://dbpedia.org/datatype/pakistaniRupee> ] [ sh:datatype <http://dbpedia.org/datatype/peruvianNuevoSol> ] [ sh:datatype <http://dbpedia.org/datatype/philippinePeso> ] [ sh:datatype <http://dbpedia.org/datatype/poundSterling> ] [ sh:datatype <http://dbpedia.org/datatype/renminbi> ] [ sh:datatype <http://dbpedia.org/datatype/russianRouble> ] [ sh:datatype <http://dbpedia.org/datatype/southAfricanRand> ] [ sh:datatype <http://dbpedia.org/datatype/sriLankanRupee> ] [ sh:datatype <http://dbpedia.org/datatype/swedishKrona> ] [ sh:datatype <http://dbpedia.org/datatype/thaiBaht> ] [ sh:datatype <http://dbpedia.org/datatype/unitedArabEmiratesDirham> ] [ sh:datatype <http://dbpedia.org/datatype/usDollar> ] ) .

