PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<MeanOfTransportation>

<MeanOfTransportation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MeanOfTransportation> ] ;
  <http://dbpedia.org/ontology/MeanOfTransportation/length> <http://dbpedia.org/datatype/millimetre> + ;
  <http://dbpedia.org/ontology/acquirementDate> xsd:date * ;
  <http://dbpedia.org/ontology/activeYearsEndDate> xsd:date ? ;
  <http://dbpedia.org/ontology/activeYearsEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/activeYearsStartDate> xsd:date ? ;
  <http://dbpedia.org/ontology/activeYearsStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/alternativeName> rdf:langString * ;
  <http://dbpedia.org/ontology/automobilePlatform> @<Automobile> ? ;
  <http://dbpedia.org/ontology/battery> @<Battery> ? ;
  <http://dbpedia.org/ontology/capacity> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/captureDate> xsd:date ? ;
  <http://dbpedia.org/ontology/commissioningDate> xsd:date ;
  <http://dbpedia.org/ontology/comparable> @<Rocket> * ;
  <http://dbpedia.org/ontology/completionDate> xsd:date ? ;
  <http://dbpedia.org/ontology/cost> @<http://shaclshapes.org/costValueShape> ? ;
  <http://dbpedia.org/ontology/country> @<Country> * ;
  <http://dbpedia.org/ontology/countryOrigin> @<Country> * ;
  <http://dbpedia.org/ontology/cylinderCount> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/decommissioningDate> xsd:date ? ;
  <http://dbpedia.org/ontology/designCompany> @<Company> * ;
  <http://dbpedia.org/ontology/designer> @<Person> * ;
  <http://dbpedia.org/ontology/diameter> xsd:double ? ;
  <http://dbpedia.org/ontology/engine> @<AutomobileEngine> ? ;
  <http://dbpedia.org/ontology/failedLaunches> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/finalFlight> xsd:date ? ;
  <http://dbpedia.org/ontology/homeport> @<Place> ? ;
  <http://dbpedia.org/ontology/launchSite> @<Building> * ;
  <http://dbpedia.org/ontology/layingDown> xsd:date ? ;
  <http://dbpedia.org/ontology/length> <http://dbpedia.org/datatype/millimetre> + ;
  <http://dbpedia.org/ontology/maidenFlight> xsd:date ? ;
  <http://dbpedia.org/ontology/maidenVoyage> xsd:date ? ;
  <http://dbpedia.org/ontology/modelEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/modelStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/motto> xsd:string ? ;
  <http://dbpedia.org/ontology/numberBuilt> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/numberOfDoors> xsd:positiveInteger * ;
  <http://dbpedia.org/ontology/orderDate> xsd:date ? ;
  <http://dbpedia.org/ontology/origin> @<PopulatedPlace> ? ;
  <http://dbpedia.org/ontology/owner> @<Agent> * ;
  <http://dbpedia.org/ontology/productionEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/productionStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/recommissioningDate> xsd:date ? ;
  <http://dbpedia.org/ontology/relatedMeanOfTransportation> @<MeanOfTransportation_class> * ;
  <http://dbpedia.org/ontology/retired> xsd:date ? ;
  <http://dbpedia.org/ontology/rocketStages> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/shipBeam> xsd:double ? ;
  <http://dbpedia.org/ontology/shipDisplacement> xsd:double * ;
  <http://dbpedia.org/ontology/shipDraft> xsd:double ? ;
  <http://dbpedia.org/ontology/shipLaunch> xsd:date ? ;
  <http://dbpedia.org/ontology/status> xsd:string ? ;
  <http://dbpedia.org/ontology/topSpeed> xsd:double ? ;
  <http://dbpedia.org/ontology/totalLaunches> xsd:nonNegativeInteger ? ;
  <http://dbpedia.org/ontology/transmission> xsd:string * ;
  <http://dbpedia.org/ontology/unitCost> @<http://shaclshapes.org/unitCostValueShape> ? ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/yearOfConstruction> xsd:gYear * ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI *
}

