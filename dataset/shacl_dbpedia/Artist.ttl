@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/ArtistShape> a sh:NodeShape ;
    sh:targetClass dbo:Artist ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Career & achievements ===
    sh:property [
        sh:path dbo:award ;
        sh:class dbo:Award ;
    ] ;

    sh:property [
        sh:path dbo:nationality ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:genre ;
        sh:class dbo:Genre ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:instrument ;
        sh:class dbo:Instrument ;
    ] ;

    sh:property [
        sh:path dbo:notableWork ;
        sh:class dbo:Work ;
    ] ;

    sh:property [
        sh:path dbo:background ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:field ;
    ] ;

    sh:property [
        sh:path dbo:movement ;
    ] ;

    sh:property [
        sh:path dbo:academicDiscipline ;
    ] ;

    sh:property [
        sh:path dbo:education ;
    ] ;

    # === Cast, crew & creators ===
    sh:property [
        sh:path dbo:associatedMusicalArtist ;
        sh:class dbo:MusicalArtist ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:birthDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:birthYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:alias ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:birthName ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:pseudonym ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:originalName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path <http://purl.org/linguistics/gold/hypernym> ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:stateOfOrigin ;
        sh:class dbo:Country ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:birthPlace ;
        sh:class dbo:Place ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathPlace ;
        sh:class dbo:Place ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:restingPlace ;
        sh:class dbo:Place ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:residence ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:hometown ;
        sh:class dbo:Settlement ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Media & publications ===
    sh:property [
        sh:path dbo:soundRecording ;
        sh:class dbo:Sound ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:associatedBand ;
        sh:class dbo:Band ;
    ] ;

    sh:property [
        sh:path dbo:institution ;
        sh:class dbo:Organisation ;
    ] ;

    sh:property [
        sh:path dbo:recordLabel ;
        sh:class dbo:RecordLabel ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:spouse ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:child ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:relative ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:partner ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:parent ;
        sh:class dbo:Person ;
        sh:maxCount 2 ;
    ] ;

    sh:property [
        sh:path dbo:doctoralAdvisor ;
        sh:class dbo:Person ;
    ] ;

    # === References & links ===
    sh:property [
        sh:path dbo:imdbId ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Physical dimensions & specs (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Person/height> ;
                sh:datatype dbt:centimetre ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:height ;
                sh:datatype dbt:centimetre ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:height ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Person/height> ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
    ) .

