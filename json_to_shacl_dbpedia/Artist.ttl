@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/ArtistShape> a sh:NodeShape ;
    sh:property [ sh:path <http://dbpedia.org/ontology/education> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/notableWork> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/relative> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/child> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/nationality> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthYear> ],
        [ sh:class <http://dbpedia.org/ontology/MusicalArtist> ;
            sh:path <http://dbpedia.org/ontology/associatedMusicalArtist> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:datatype xsd:gYear ;
