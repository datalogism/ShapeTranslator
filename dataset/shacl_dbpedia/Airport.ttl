@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/AirportShape> a sh:NodeShape ;
    sh:targetClass dbo:Airport ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:foundingDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:openingDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:yearOfConstruction ;
        sh:datatype xsd:gYear ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:openingYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:foundingYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:buildingEndDate ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> ;
        sh:datatype dbt:squareKilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaTotal ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:area ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:areaLand ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:nrhpReferenceNumber ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:originalName ;
        sh:datatype rdf:langString ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:agencyStationCode ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:city ;
        sh:class dbo:City ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:locatedInArea ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:district ;
        sh:class dbo:PopulatedPlace ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:nearestCity ;
        sh:class dbo:PopulatedPlace ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:principalArea ;
        sh:class dbo:PopulatedPlace ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeEnd ;
        sh:class dbo:Station ;
        sh:maxCount 5 ;
    ] ;

    sh:property [
        sh:path dbo:routeStart ;
        sh:class dbo:Station ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeJunction ;
        sh:class dbo:Station ;
    ] ;

    sh:property [
        sh:path dbo:icaoLocationIdentifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:iataLocationIdentifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:faaLocationIdentifier ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:locationIdentifier ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:postalCode ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:areaCode ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:gridReference ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:utcOffset ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeNumber ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeTypeAbbreviation ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeStartDirection ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:routeEndDirection ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path <http://dbpedia.org/ontology/Infrastructure/length> ;
        sh:datatype dbt:kilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:elevation ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:runwayLength ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
    ] ;

    # === Politics & governance ===
    sh:property [
        sh:path dbo:commander ;
        sh:class dbo:Person ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:runwaySurface ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:runwayDesignation ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .

