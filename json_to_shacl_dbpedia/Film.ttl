<http://shaclshapes.org/FilmShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/openingTheme> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/country> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/director> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/writer> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/cinematography> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/musicBy> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:class <http://dbpedia.org/ontology/Genre> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/genre> ],
        [ sh:datatype <http://dbpedia.org/datatype/minute> ;
            sh:path <http://dbpedia.org/ontology/Work/runtime> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/alias> ],
        [ sh:class <http://dbpedia.org/ontology/Actor> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/starring> ],
        [ sh:class <http://dbpedia.org/ontology/Sound> ;
            sh:path <http://dbpedia.org/ontology/soundRecording> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/author> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/editing> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:path <http://dbpedia.org/ontology/creator> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/distributor> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:path <http://dbpedia.org/ontology/location> ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/previousWork> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path <http://dbpedia.org/ontology/numberOfSeasons> ],
        [ sh:class <http://dbpedia.org/ontology/Award> ;
            sh:path <http://dbpedia.org/ontology/award> ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node <http://shaclshapes.org/budgetValueShape> ;
            sh:path <http://dbpedia.org/ontology/budget> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Work> ;
            sh:path <http://dbpedia.org/ontology/subsequentWork> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/publisher> ],
        [ sh:class <http://dbpedia.org/ontology/Company> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/productionCompany> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/gross> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/keyPerson> ],
