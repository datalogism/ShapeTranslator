PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<Politician>

<Politician> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Politician> ] ;
  <http://dbpedia.org/ontology/Person/height> <http://dbpedia.org/datatype/centimetre> ? ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/activeYearsEndDate> xsd:date ? ;
  <http://dbpedia.org/ontology/activeYearsEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/activeYearsStartDate> xsd:date ? ;
  <http://dbpedia.org/ontology/activeYearsStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/alias> rdf:langString * ;
  <http://dbpedia.org/ontology/almaMater> @<EducationalInstitution> * ;
  <http://dbpedia.org/ontology/appointer> @<Person> * ;
  <http://dbpedia.org/ontology/associate> @<Person> * ;
  <http://dbpedia.org/ontology/award> @<Award> * ;
  <http://dbpedia.org/ontology/battle> @<MilitaryConflict> * ;
  <http://dbpedia.org/ontology/birthDate> xsd:date ;
  <http://dbpedia.org/ontology/birthName> rdf:langString ;
  <http://dbpedia.org/ontology/birthPlace> @<Place> ;
  <http://dbpedia.org/ontology/birthYear> xsd:gYear ;
  <http://dbpedia.org/ontology/chancellor> @<Person> * ;
  <http://dbpedia.org/ontology/child> @<Person> * ;
  <http://dbpedia.org/ontology/committee> xsd:string * ;
  <http://dbpedia.org/ontology/country> @<Country> + ;
  <http://dbpedia.org/ontology/deathDate> xsd:date ? ;
  <http://dbpedia.org/ontology/deathPlace> @<Place> ? ;
  <http://dbpedia.org/ontology/deathYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/deputy> @<Person> * ;
  <http://dbpedia.org/ontology/education> . + ;
  <http://dbpedia.org/ontology/electionMajority> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/father> @<Person> ? ;
  <http://dbpedia.org/ontology/governor> @<Person> * ;
  <http://dbpedia.org/ontology/governorGeneral> @<Person> ? ;
  <http://dbpedia.org/ontology/height> xsd:double ? ;
  <http://dbpedia.org/ontology/imdbId> xsd:string * ;
  <http://dbpedia.org/ontology/lieutenant> @<Person> * ;
  <http://dbpedia.org/ontology/militaryBranch> @<MilitaryUnit> * ;
  <http://dbpedia.org/ontology/militaryCommand> xsd:string * ;
  <http://dbpedia.org/ontology/militaryService> @<MilitaryService> ? ;
  <http://dbpedia.org/ontology/militaryUnit> @<MilitaryUnit> * ;
  <http://dbpedia.org/ontology/monarch> @<Person> * ;
  <http://dbpedia.org/ontology/mother> @<Person> ? ;
  <http://dbpedia.org/ontology/nationality> @<Country> + ;
  <http://dbpedia.org/ontology/occupation> @<PersonFunction> + ;
  <http://dbpedia.org/ontology/office> xsd:string * ;
  <http://dbpedia.org/ontology/orderInOffice> xsd:string * ;
  <http://dbpedia.org/ontology/originalName> rdf:langString ? ;
  <http://dbpedia.org/ontology/otherParty> @<PoliticalParty> * ;
  <http://dbpedia.org/ontology/parent> @<Person> {0,2} ;
  <http://dbpedia.org/ontology/partner> @<Person> * ;
  <http://dbpedia.org/ontology/party> @<PoliticalParty> * ;
  <http://dbpedia.org/ontology/portfolio> xsd:string * ;
  <http://dbpedia.org/ontology/president> @<Person> * ;
  <http://dbpedia.org/ontology/primeMinister> @<Person> * ;
  <http://dbpedia.org/ontology/region> @<Place> * ;
  <http://dbpedia.org/ontology/relation> @<Person> * ;
  <http://dbpedia.org/ontology/relative> @<Person> * ;
  <http://dbpedia.org/ontology/residence> @<Place> + ;
  <http://dbpedia.org/ontology/restingPlace> @<Place> ? ;
  <http://dbpedia.org/ontology/restingPlacePosition> @<wgs84_pos#SpatialThing> ? ;
  <http://dbpedia.org/ontology/seniority> xsd:string * ;
  <http://dbpedia.org/ontology/serviceEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/serviceStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/signature> xsd:string ? ;
  <http://dbpedia.org/ontology/soundRecording> @<Sound> * ;
  <http://dbpedia.org/ontology/spouse> @<Person> * ;
  <http://dbpedia.org/ontology/stateOfOrigin> @<Country> ? ;
  <http://dbpedia.org/ontology/termPeriod> @<TimePeriod> + ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/vicePresident> @<Person> * ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/name> rdf:langString
}

<Award> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Award> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<EducationalInstitution> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/EducationalInstitution> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<MilitaryConflict> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MilitaryConflict> ]
}

<MilitaryService> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MilitaryService> ]
}

<MilitaryUnit> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MilitaryUnit> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<PersonFunction> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PersonFunction> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PoliticalParty> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PoliticalParty> ]
}

<Sound> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Sound> ]
}

<TimePeriod> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/TimePeriod> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}

<wgs84_pos#SpatialThing> EXTRA rdf:type {
  rdf:type [ <http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing> ]
}
