PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<Scientist>

<Scientist> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Scientist> ] ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/academicAdvisor> @<Person> * ;
  <http://dbpedia.org/ontology/activeYearsEndYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/activeYearsStartYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/almaMater> @<EducationalInstitution> * ;
  <http://dbpedia.org/ontology/award> @<Award> * ;
  <http://dbpedia.org/ontology/birthDate> xsd:date ;
  <http://dbpedia.org/ontology/birthPlace> @<Place> ? ;
  <http://dbpedia.org/ontology/birthYear> xsd:gYear ;
  <http://dbpedia.org/ontology/child> @<Person> * ;
  <http://dbpedia.org/ontology/citizenship> @<Country> + ;
  <http://dbpedia.org/ontology/country> @<Country> + ;
  <http://dbpedia.org/ontology/deathDate> xsd:date ? ;
  <http://dbpedia.org/ontology/deathPlace> @<Place> ? ;
  <http://dbpedia.org/ontology/deathYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/depictionDescription> rdf:langString ? ;
  <http://dbpedia.org/ontology/doctoralAdvisor> @<Person> * ;
  <http://dbpedia.org/ontology/doctoralStudent> @<Person> * ;
  <http://dbpedia.org/ontology/employer> @<Organisation> * ;
  <http://dbpedia.org/ontology/imdbId> xsd:string * ;
  <http://dbpedia.org/ontology/institution> @<Organisation> + ;
  <http://dbpedia.org/ontology/nationality> @<Country> + ;
  <http://dbpedia.org/ontology/notableStudent> @<Person> * ;
  <http://dbpedia.org/ontology/occupation> @<PersonFunction> + ;
  <http://dbpedia.org/ontology/party> @<PoliticalParty> * ;
  <http://dbpedia.org/ontology/region> @<Place> * ;
  <http://dbpedia.org/ontology/residence> @<Place> + ;
  <http://dbpedia.org/ontology/soundRecording> @<Sound> * ;
  <http://dbpedia.org/ontology/spouse> @<Person> * ;
  <http://dbpedia.org/ontology/stateOfOrigin> @<Country> ? ;
  <http://dbpedia.org/ontology/termPeriod> @<TimePeriod> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/title> rdf:langString * ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  owl:sameAs xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI *
}

<Award> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Award> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<EducationalInstitution> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/EducationalInstitution> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Organisation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Organisation> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<PersonFunction> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PersonFunction> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PoliticalParty> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PoliticalParty> ]
}

<Sound> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Sound> ]
}

<TimePeriod> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/TimePeriod> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
