@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/AstronautShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/deathDate> ],
        [ sh:hasValue <http://dbpedia.org/ontology/Astronaut> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:path <http://purl.org/linguistics/gold/hypernym> ],
        [ sh:class <http://dbpedia.org/ontology/PersonFunction> ;
            sh:path <http://dbpedia.org/ontology/occupation> ],
        [ sh:datatype xsd:double ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/timeInSpace> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthDate> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/status> ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:class <http://dbpedia.org/ontology/SpaceMission> ;
            sh:path <http://dbpedia.org/ontology/mission> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/retired> ],
        [ sh:class <http://dbpedia.org/ontology/Award> ;
            sh:path <http://dbpedia.org/ontology/award> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/nationality> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthPlace> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/deathPlace> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype rdf:langString ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthName> ],
        [ sh:class <http://dbpedia.org/ontology/EducationalInstitution> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/almaMater> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:double ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/Astronaut/timeInSpace> ] ;
    sh:targetClass <http://dbpedia.org/ontology/Astronaut> .

