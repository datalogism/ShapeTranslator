org/datatype/renminbi> OR <http://dbpedia.org/datatype/russianRouble> OR <http://dbpedia.org/datatype/saudiRiyal> OR <http://dbpedia.org/datatype/serbianDinar> OR <http://dbpedia.org/datatype/slovakKoruna> OR <http://dbpedia.org/datatype/southKoreanWon> OR <http://dbpedia.org/datatype/sriLankanRupee> OR <http://dbpedia.org/datatype/swedishKrona> OR <http://dbpedia.org/datatype/swissFranc> OR <http://dbpedia.org/datatype/tanzanianShilling> OR <http://dbpedia.org/datatype/thaiBaht> OR <http://dbpedia.org/datatype/turkishLira> OR <http://dbpedia.org/datatype/ugandaShilling> OR <http://dbpedia.org/datatype/unitedArabEmiratesDirham> OR <http://dbpedia.org/datatype/usDollar>

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<Architect> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Architect> ]
}

<Award> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Award> ]
}

<City> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/City> ]
}

<Company> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Company> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<Genre> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Genre> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Organisation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Organisation> ]
}

<Place> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Place> ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PopulatedPlace> ]
}

<School> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/School> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
