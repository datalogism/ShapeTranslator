@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/AstronautShape> a sh:NodeShape ;
    sh:targetClass dbo:Astronaut ;

    # ═══════════════════════════════════════════════════════════════════════════
    # IDENTITY & NAMING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path rdfs:label ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:name ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:birthName ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DESCRIPTION & ABSTRACT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:abstract ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DATES & TIMELINE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:birthDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:retired ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # LOCATION & GEOGRAPHY
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:birthPlace ;
        sh:class dbo:Place ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:deathPlace ;
        sh:class dbo:Place ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:nationality ;
        sh:class dbo:Country ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # CAREER & ACHIEVEMENTS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:occupation ;
        sh:class dbo:PersonFunction ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:award ;
        sh:class dbo:Award ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:status ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SPACE MISSIONS & SELECTION
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:selection ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:mission ;
        sh:class dbo:SpaceMission ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # TIME IN SPACE (alternative representations)
    # ═══════════════════════════════════════════════════════════════════════════

    sh:or (
        [
            sh:property [
                sh:path dbo:timeInSpace ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Astronaut/timeInSpace> ;
                sh:datatype dbt:minute ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EDUCATION & AFFILIATION
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:almaMater ;
        sh:class dbo:EducationalInstitution ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # MEDIA & IMAGES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EXTERNAL REFERENCES & LINKS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path foaf:homepage ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # WIKIPEDIA & DBPEDIA METADATA
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] .
