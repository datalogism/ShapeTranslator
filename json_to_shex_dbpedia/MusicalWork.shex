PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>

start = @<MusicalWork>

<MusicalWork> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MusicalWork> ] ;
  <http://dbpedia.org/ontology/Work/runtime> <http://dbpedia.org/datatype/minute> ? ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/album> @<Album> * ;
  <http://dbpedia.org/ontology/artist> @<Agent> + ;
  <http://dbpedia.org/ontology/associatedBand> @<Band> * ;
  <http://dbpedia.org/ontology/associatedMusicalArtist> @<MusicalArtist> * ;
  <http://dbpedia.org/ontology/author> @<Person> * ;
  <http://dbpedia.org/ontology/award> @<Award> * ;
  <http://dbpedia.org/ontology/bSide> xsd:string ? ;
  <http://dbpedia.org/ontology/basedOn> @<Work> * ;
  <http://dbpedia.org/ontology/budget> @<http://shaclshapes.org/budgetValueShape> ? ;
  <http://dbpedia.org/ontology/cinematography> @<Person> * ;
  <http://dbpedia.org/ontology/composer> @<Person> * ;
  <http://dbpedia.org/ontology/country> @<Country> * ;
  <http://dbpedia.org/ontology/director> @<Person> * ;
  <http://dbpedia.org/ontology/distributor> @<Organisation> * ;
  <http://dbpedia.org/ontology/editing> @<Person> * ;
  <http://dbpedia.org/ontology/genre> @<Genre> + ;
  <http://dbpedia.org/ontology/imdbId> xsd:string * ;
  <http://dbpedia.org/ontology/language> @<Language> * ;
  <http://dbpedia.org/ontology/lyrics> @<Person> * ;
  <http://dbpedia.org/ontology/musicBy> @<Person> * ;
  <http://dbpedia.org/ontology/musicComposer> @<MusicalArtist> * ;
  <http://dbpedia.org/ontology/origin> @<PopulatedPlace> * ;
  <http://dbpedia.org/ontology/previousWork> @<Work> * ;
  <http://dbpedia.org/ontology/producer> @<Agent> * ;
  <http://dbpedia.org/ontology/productionCompany> @<Company> * ;
  <http://dbpedia.org/ontology/publicationDate> xsd:date ? ;
  <http://dbpedia.org/ontology/recordDate> xsd:date ;
  <http://dbpedia.org/ontology/recordLabel> @<RecordLabel> * ;
  <http://dbpedia.org/ontology/recordedIn> @<PopulatedPlace> * ;
  <http://dbpedia.org/ontology/releaseDate> xsd:date ? ;
  <http://dbpedia.org/ontology/runtime> xsd:double ? ;
  <http://dbpedia.org/ontology/runtime> @<PopulatedPlace> * ;
  <http://dbpedia.org/ontology/soundRecording> @<Sound> * ;
  <http://dbpedia.org/ontology/starring> @<Actor> * ;
  <http://dbpedia.org/ontology/subsequentWork> @<Work> * ;
  <http://dbpedia.org/ontology/subtitle> xsd:string * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/title> rdf:langString ? ;
  <http://dbpedia.org/ontology/wikiPageDisambiguates> . ? ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageInterLanguageLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/writer> @<Person> * ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  rdfs:seeAlso xsd:anyURI * ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/homepage> @<Document> ? ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/name> rdfs:Literal *
}

<budgetValue> <http://dbpedia.org/datatype/canadianDollar> OR <http://dbpedia.org/datatype/croatianKuna> OR <http://dbpedia.org/datatype/danishKrone> OR <http://dbpedia.org/datatype/euro> OR <http://dbpedia.org/datatype/hungarianForint> OR <http://dbpedia.org/datatype/indianRupee> OR <http://dbpedia.org/datatype/japaneseYen> OR <http://dbpedia.org/datatype/jordanianDinar> OR <http://dbpedia.org/datatype/lebanesePound> OR <http://dbpedia.org/datatype/malaysianRinggit> OR <http://dbpedia.org/datatype/nepaleseRupee> OR <http://dbpedia.org/datatype/netherlandsAntilleanGuilder> OR <http://dbpedia.org/datatype/pakistaniRupee> OR <http://dbpedia.org/datatype/peruvianNuevoSol> OR <http://dbpedia.org/datatype/philippinePeso> OR <http://dbpedia.org/datatype/poundSterling> OR <http://dbpedia.org/datatype/renminbi> OR <http://dbpedia.org/datatype/russianRouble> OR <http://dbpedia.org/datatype/southAfricanRand> OR <http://dbpedia.org/datatype/sriLankanRupee> OR <http://dbpedia.org/datatype/swedishKrona> OR <http://dbpedia.org/datatype/thaiBaht> OR <http://dbpedia.org/datatype/unitedArabEmiratesDirham> OR <http://dbpedia.org/datatype/usDollar>

<Actor> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Actor> ]
}

<Agent> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Agent> ]
}

<Album> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Album> ]
}

<Award> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Award> ]
}

<Band> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Band> ]
}

<Company> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Company> ]
}

<Country> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Country> ]
}

<Document> EXTRA rdf:type {
  rdf:type [ <http://xmlns.com/foaf/0.1/Document> ]
}

<Genre> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Genre> ]
}

<Image> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Image> ]
}

<Language> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Language> ]
}

<MusicalArtist> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/MusicalArtist> ]
}

<Organisation> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Organisation> ]
}

<Person> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Person> ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/PopulatedPlace> ]
}

<RecordLabel> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/RecordLabel> ]
}

<Sound> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Sound> ]
}

<Work> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Work> ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
