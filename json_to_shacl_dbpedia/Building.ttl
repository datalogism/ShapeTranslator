            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/currentlyUsedFor> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/governingBody> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:path <http://dbpedia.org/ontology/owner> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/alternativeName> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/numberOfRooms> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/formerName> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path <http://dbpedia.org/ontology/bedCount> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/foundingDate> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/buildingStartDate> ],
        [ sh:hasValue <http://dbpedia.org/ontology/Building> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/code> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/collection> ] ;
    sh:targetClass <http://dbpedia.org/ontology/Building> .

