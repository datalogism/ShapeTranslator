@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/MeanOfTransportationShape> a sh:NodeShape ;
    sh:targetClass dbo:MeanOfTransportation ;

    # ═══════════════════════════════════════════════════════════════════════════
    # IDENTITY & NAMING
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:alternativeName ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:motto ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DESCRIPTION & ABSTRACT
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:abstract ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # DATES & TIMELINE
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:commissioningDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:decommissioningDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:recommissioningDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:orderDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:layingDown ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:completionDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:acquirementDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:captureDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndDate ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:retired ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SHIP-SPECIFIC DATES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:shipLaunch ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:maidenVoyage ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # AIRCRAFT & ROCKET-SPECIFIC DATES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:maidenFlight ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:finalFlight ;
        sh:datatype xsd:date ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # PRODUCTION & MODEL YEARS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:productionStartYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:productionEndYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:modelStartYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:modelEndYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsStartYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:activeYearsEndYear ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:yearOfConstruction ;
        sh:datatype xsd:gYear ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # LOCATION & ORIGIN
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:countryOrigin ;
        sh:class dbo:Country ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:origin ;
        sh:class dbo:PopulatedPlace ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:homeport ;
        sh:class dbo:Place ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:launchSite ;
        sh:class dbo:Building ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # OWNERSHIP & DESIGN
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:designer ;
        sh:class dbo:Agent ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:designCompany ;
        sh:class dbo:Company ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # PRODUCTION & ECONOMICS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:numberBuilt ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:cost ;
        sh:node shapes:costValueShape ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:unitCost ;
        sh:node shapes:costValueShape ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # LAUNCH STATISTICS (Rockets)
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:totalLaunches ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:failedLaunches ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:rocketStages ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # PHYSICAL DIMENSIONS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:diameter ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # --- Length (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/length> ;
                sh:datatype dbt:millimetre ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:length ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    # --- Height (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/height> ;
                sh:datatype dbt:millimetre ;
                sh:nodeKind sh:Literal ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:height ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
            ]
        ]
    ) ;

    # --- Width (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/width> ;
                sh:datatype dbt:millimetre ;
                sh:nodeKind sh:Literal ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:width ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
            ]
        ]
    ) ;

    # --- Weight (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path dbo:weight ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
            ]
        ]
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/MeanOfTransportation/weight> ;
                sh:datatype dbt:kilogram ;
                sh:nodeKind sh:Literal ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # SHIP-SPECIFIC DIMENSIONS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:shipBeam ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:shipDraft ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:shipDisplacement ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # AUTOMOBILE-SPECIFIC SPECIFICATIONS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:automobilePlatform ;
        sh:class dbo:Automobile ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:numberOfDoors ;
        sh:datatype xsd:positiveInteger ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:cylinderCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:transmission ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
    ] ;

    # --- Wheelbase (alternative representations) ---
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Automobile/wheelbase> ;
                sh:datatype dbt:millimetre ;
                sh:nodeKind sh:Literal ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:wheelbase ;
                sh:datatype xsd:double ;
                sh:nodeKind sh:Literal ;
            ]
        ]
    ) ;

    # ═══════════════════════════════════════════════════════════════════════════
    # ENGINE & POWER
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:engine ;
        sh:class dbo:AutomobileEngine ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:battery ;
        sh:class dbo:Battery ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # PERFORMANCE & CAPACITY
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:topSpeed ;
        sh:datatype xsd:double ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:capacity ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # STATUS & CLASSIFICATION
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:status ;
        sh:datatype xsd:string ;
        sh:nodeKind sh:Literal ;
        sh:maxCount 1 ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # RELATED VEHICLES
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:relatedMeanOfTransportation ;
        sh:class dbo:MeanOfTransportation ;
        sh:nodeKind sh:IRI ;
    ] ;

    sh:property [
        sh:path dbo:comparable ;
        sh:class dbo:Rocket ;
        sh:nodeKind sh:IRI ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # EXTERNAL REFERENCES & LINKS
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:Literal ;
    ] ;

    # ═══════════════════════════════════════════════════════════════════════════
    # WIKIPEDIA & DBPEDIA METADATA
    # ═══════════════════════════════════════════════════════════════════════════

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
        sh:nodeKind sh:Literal ;
    ] .


# ═══════════════════════════════════════════════════════════════════════════════
# REUSABLE VALUE SHAPES
# ═══════════════════════════════════════════════════════════════════════════════

shapes:costValueShape a sh:NodeShape ;
    sh:or (
        [ sh:datatype dbt:usDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:poundSterling ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:euro ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:japaneseYen ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:canadianDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:swedishKrona ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:norwegianKrone ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:danishKrone ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:swissFranc ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:australianDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:malaysianRinggit ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:russianRouble ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:indonesianRupiah ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:polishZ%C5%82oty ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:unitedArabEmiratesDirham ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:renminbi ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:czechKoruna ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:indianRupee ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:bulgarianLev ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:sriLankanRupee ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:hungarianForint ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:southKoreanWon ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:lithuanianLitas ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:croatianKuna ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:iraqiDinar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:mexicanPeso ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:saudiRiyal ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:turkishLira ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:estonianKroon ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:hongKongDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:newTaiwanDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:thaiBaht ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:pakistaniRupee ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:slovakKoruna ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:chileanPeso ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:kuwaitiDinar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:newZealandDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:bangladeshiTaka ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:philippinePeso ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:serbianDinar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:brazilianReal ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:tanzanianShilling ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:georgianLari ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:algerianDinar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:armenianDram ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:colombianPeso ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:argentinePeso ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:israeliNewSheqel ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:moroccanDirham ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:egyptianPound ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:lebanesePound ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:iranianRial ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:capeVerdeEscudo ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:kenyanShilling ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:ugandaShilling ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:bruneiDollar ; sh:nodeKind sh:Literal ]
        [ sh:datatype dbt:cambodianRiel ; sh:nodeKind sh:Literal ]
    ) .
