@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/CelestialBodyShape> a sh:NodeShape ;
    sh:targetClass dbo:CelestialBody ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:discovered ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:epoch ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:formerName ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:abbreviation ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:neighbourConstellations ;
        sh:datatype xsd:string ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:discoverer ;
        sh:class dbo:Person ;
        sh:minCount 1 ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path <http://dbpedia.org/ontology/Planet/volume> ;
        sh:datatype dbt:cubicKilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/Planet/minimumTemperature> ;
        sh:datatype dbt:kelvin ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/Planet/periapsis> ;
        sh:datatype dbt:kilometre ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/Planet/meanRadius> ;
        sh:datatype dbt:kilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path <http://dbpedia.org/ontology/Planet/surfaceArea> ;
        sh:datatype dbt:squareKilometre ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:periapsis ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:apoapsis ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:absoluteMagnitude ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:rotationPeriod ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:escapeVelocity ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:surfaceArea ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:albedo ;
        sh:datatype xsd:double ;
    ] ;

    sh:property [
        sh:path dbo:apparentMagnitude ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:meanRadius ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:averageSpeed ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:density ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:volume ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:orbitalPeriod ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:detectionMethod ;
        sh:datatype xsd:string ;
    ] ;

    # === Physical dimensions & specs (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/orbitalPeriod> ;
                sh:datatype dbt:day ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:orbitalPeriod ;
                sh:datatype dbt:day ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/temperature> ;
                sh:datatype dbt:kelvin ;
                sh:minCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:temperature ;
                sh:datatype dbt:kelvin ;
                sh:minCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/maximumTemperature> ;
                sh:datatype dbt:kelvin ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:averageSpeed ;
                sh:datatype dbt:kelvin ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/mass> ;
                sh:datatype dbt:kilogram ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:mass ;
                sh:datatype dbt:kilogram ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/density> ;
                sh:datatype dbt:kilogramPerCubicMetre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:density ;
                sh:datatype dbt:kilogramPerCubicMetre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/apoapsis> ;
                sh:datatype dbt:kilometre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:apoapsis ;
                sh:datatype dbt:kilometre ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path <http://dbpedia.org/ontology/Planet/averageSpeed> ;
                sh:datatype dbt:kilometrePerSecond ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:averageSpeed ;
                sh:datatype dbt:kilometrePerSecond ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:temperature ;
                sh:datatype xsd:double ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:density ;
                sh:datatype xsd:double ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:mass ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:mass ;
                sh:datatype xsd:double ;
                sh:maxCount 1 ;
            ]
        ]
    ) .

