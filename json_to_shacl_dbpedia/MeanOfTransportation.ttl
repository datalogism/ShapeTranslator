@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/MeanOfTransportationShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:positiveInteger ;
            sh:path <http://dbpedia.org/ontology/numberOfDoors> ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/status> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/totalLaunches> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/layingDown> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/shipDraft> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/origin> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/decommissioningDate> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/productionStartYear> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/retired> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/diameter> ],
        [ sh:class <http://dbpedia.org/ontology/AutomobileEngine> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/engine> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/modelEndYear> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsStartDate> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/productionEndYear> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/maidenFlight> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:path <http://dbpedia.org/ontology/country> ],
        [ sh:class <http://dbpedia.org/ontology/Rocket> ;
            sh:path <http://dbpedia.org/ontology/comparable> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/shipLaunch> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/motto> ],
        [ sh:datatype xsd:date ;
            sh:path <http://dbpedia.org/ontology/acquirementDate> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path <http://dbpedia.org/ontology/capacity> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/maidenVoyage> ],
        [ sh:class <http://dbpedia.org/ontology/Building> ;
            sh:path <http://dbpedia.org/ontology/launchSite> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/topSpeed> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/captureDate> ],
        [ sh:class <http://dbpedia.org/ontology/Automobile> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/automobilePlatform> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:differentFrom ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/finalFlight> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/recommissioningDate> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/designer> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsEndYear> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:path <http://dbpedia.org/ontology/countryOrigin> ],
        [ sh:hasValue <http://dbpedia.org/ontology/MeanOfTransportation> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Battery> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/battery> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/completionDate> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/orderDate> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/transmission> ],
        [ sh:maxCount 1 ;
            sh:node <http://shaclshapes.org/unitCostValueShape> ;
            sh:path <http://dbpedia.org/ontology/unitCost> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:path <http://dbpedia.org/ontology/owner> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/commissioningDate> ],
        [ sh:datatype <http://dbpedia.org/datatype/millimetre> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/MeanOfTransportation/length> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/cylinderCount> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/alternativeName> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/homeport> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageInterLanguageLink> ],
        [ sh:datatype xsd:double ;
            sh:path <http://dbpedia.org/ontology/shipDisplacement> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/failedLaunches> ],
        [ sh:maxCount 1 ;
            sh:node <http://shaclshapes.org/costValueShape> ;
            sh:path <http://dbpedia.org/ontology/cost> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/modelStartYear> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsStartYear> ],
        [ sh:datatype xsd:gYear ;
            sh:path <http://dbpedia.org/ontology/yearOfConstruction> ],
        [ sh:class <http://dbpedia.org/ontology/MeanOfTransportation> ;
            sh:path <http://dbpedia.org/ontology/relatedMeanOfTransportation> ],
        [ sh:datatype <http://dbpedia.org/datatype/millimetre> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/length> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsEndDate> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/rocketStages> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/numberBuilt> ],
        [ sh:class <http://dbpedia.org/ontology/Company> ;
            sh:path <http://dbpedia.org/ontology/designCompany> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/shipBeam> ] ;
    sh:targetClass <http://dbpedia.org/ontology/MeanOfTransportation> .

