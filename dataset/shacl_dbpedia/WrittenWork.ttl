@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/WrittenWorkShape> a sh:NodeShape ;
    sh:targetClass dbo:WrittenWork ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageInterLanguageLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:seeAlso ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    # === Career & achievements ===
    sh:property [
        sh:path dbo:genre ;
        sh:class dbo:Genre ;
    ] ;

    # === Cast, crew & creators ===
    sh:property [
        sh:path dbo:editor ;
        sh:class dbo:Agent ;
    ] ;

    sh:property [
        sh:path dbo:author ;
        sh:class dbo:Person ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:coverArtist ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:illustrator ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:writer ;
        sh:class dbo:Person ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:translator ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:previousEditor ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:chiefEditor ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:editorTitle ;
        sh:datatype rdf:langString ;
        sh:maxCount 1 ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:releaseDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:publicationDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:firstPublicationDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:lastPublicationDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:foundingDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:premiereDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:firstPublicationYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:premiereYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:finalPublicationYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path dbo:impactFactor ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:circulation ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:numberOfVolumes ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:numberOfPages ;
        sh:datatype xsd:positiveInteger ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:abbreviation ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:isbn ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:oclc ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:issn ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:lcc ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:dcc ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:lccn ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:coden ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:city ;
        sh:class dbo:City ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
    ] ;

    # === Media & publications ===
    sh:property [
        sh:path dbo:language ;
        sh:class dbo:Language ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:originalLanguage ;
        sh:class dbo:Language ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:depictionDescription ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:imageSize ;
        sh:datatype xsd:integer ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:frequencyOfPublication ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:openAccessContent ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:logo ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:publisher ;
        sh:class dbo:Agent ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:magazine ;
        sh:class dbo:Magazine ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:sisterNewspaper ;
        sh:class dbo:Newspaper ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
    ] ;

    # === References & links ===
    sh:property [
        sh:path dbo:subsequentWork ;
        sh:class dbo:Work ;
    ] ;

    sh:property [
        sh:path dbo:previousWork ;
        sh:class dbo:Work ;
    ] ;

    sh:property [
        sh:path dbo:settingOfPlay ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:characterInPlay ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:subjectOfPlay ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:jstor ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:imdbId ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

