@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbt: <http://dbpedia.org/datatype/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@prefix umbel: <http://umbel.org/umbel/rc/> .
@prefix shapes: <http://shaclshapes.org/> .


<http://shaclshapes.org/FoodShape> a sh:NodeShape ;
    sh:targetClass dbo:Food ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:year ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:foundingYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:alias ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:iupacName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:ingredientName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
    ] ;

    sh:property [
        sh:path dbo:region ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:regionServed ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:origin ;
        sh:class dbo:PopulatedPlace ;
    ] ;

    # === Media & publications ===
    sh:property [
        sh:path dbo:notes ;
        sh:datatype xsd:string ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:owningCompany ;
        sh:class dbo:Company ;
    ] ;

    sh:property [
        sh:path dbo:manufacturer ;
        sh:class dbo:Organisation ;
    ] ;

    sh:property [
        sh:path dbo:distributor ;
        sh:class dbo:Organisation ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
    ] ;

    sh:property [
        sh:path dbo:keyPerson ;
        sh:class dbo:Person ;
    ] ;

    # === Physical dimensions & specs ===
    sh:property [
        sh:path dbo:protein ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:servingSize ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:approximateCalories ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:servingTemperature ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:species ;
        sh:class dbo:Species ;
    ] ;

    sh:property [
        sh:path dbo:cuisine ;
        sh:datatype xsd:string ;
    ] .

