        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/narrator> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/releaseDate> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path <http://dbpedia.org/ontology/numberOfEpisodes> ],
        [ sh:datatype <http://dbpedia.org/datatype/minute> ;
            sh:path <http://dbpedia.org/ontology/runtime> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/imdbId> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/composer> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/editor> ],
        [ sh:hasValue <http://dbpedia.org/ontology/Film> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/lyrics> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/producer> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/company> ],
        [ sh:class <http://dbpedia.org/ontology/Language> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/language> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ] ;
    sh:targetClass <http://dbpedia.org/ontology/Film> .

