@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/CelestialBodyShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:datatype <http://dbpedia.org/datatype/kelvin> ;
            sh:path <http://dbpedia.org/ontology/Planet/minimumTemperature> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/meanRadius> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/detectionMethod> ],
        [ sh:datatype <http://dbpedia.org/datatype/kilometre> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/Planet/periapsis> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/formerName> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/neighbourConstellations> ],
        [ sh:datatype xsd:double ;
            sh:path <http://dbpedia.org/ontology/absoluteMagnitude> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/surfaceArea> ],
        [ sh:hasValue <http://dbpedia.org/ontology/CelestialBody> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:datatype xsd:date ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/discovered> ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype xsd:double ;
            sh:path <http://dbpedia.org/ontology/albedo> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/apoapsis> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype <http://dbpedia.org/datatype/kilometre> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/Planet/meanRadius> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abbreviation> ],
        [ sh:datatype <http://dbpedia.org/datatype/squareKilometre> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/Planet/surfaceArea> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype <http://dbpedia.org/datatype/cubicKilometre> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/Planet/volume> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/apparentMagnitude> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype <http://dbpedia.org/datatype/day> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/Planet/orbitalPeriod> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/density> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/volume> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:differentFrom ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/discoverer> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/escapeVelocity> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/rotationPeriod> ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/epoch> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/periapsis> ],
        [ sh:datatype <http://dbpedia.org/datatype/day> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/orbitalPeriod> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:double ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/orbitalPeriod> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/averageSpeed> ] ;
    sh:targetClass <http://dbpedia.org/ontology/CelestialBody> .

