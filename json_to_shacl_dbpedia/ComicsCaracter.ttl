@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/ComicsCaracterShape> a sh:NodeShape ;
    sh:property [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/firstAppearance> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:differentFrom ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/imdbId> ],
        [ sh:path <http://dbpedia.org/ontology/wikiPageDisambiguates> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:hasValue <http://dbpedia.org/ontology/ComicsCharacter> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/publisher> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:class <http://dbpedia.org/ontology/Agent> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/creator> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageInterLanguageLink> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/writer> ] ;
    sh:targetClass <http://dbpedia.org/ontology/ComicsCharacter> .

