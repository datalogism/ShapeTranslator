PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX yago: <http://yago-knowledge.org/resource/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX dbo: <http://dbpedia.org/ontology/>
PREFIX dbt: <http://dbpedia.org/datatype/>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX shapes: <http://shaclshapes.org/>

start = @<Company>

<assetUnderManagementValue> dbt:usDollar OR dbt:euro OR dbt:poundSterling OR dbt:swissFranc OR dbt:japaneseYen OR dbt:renminbi OR dbt:sriLankanRupee OR dbt:swedishKrona OR dbt:moroccanDirham OR dbt:canadianDollar OR dbt:russianRouble OR dbt:norwegianKrone OR dbt:australianDollar OR dbt:southKoreanWon OR dbt:czechKoruna OR dbt:unitedArabEmiratesDirham OR dbt:danishKrone

<assetsValue> dbt:usDollar OR dbt:euro OR dbt:renminbi OR dbt:japaneseYen OR dbt:poundSterling OR dbt:sriLankanRupee OR dbt:canadianDollar OR dbt:swedishKrona OR dbt:kenyanShilling OR dbt:swissFranc OR dbt:norwegianKrone OR dbt:danishKrone OR dbt:philippinePeso OR dbt:southKoreanWon OR dbt:czechKoruna OR dbt:malaysianRinggit OR dbt:russianRouble OR dbt:hongKongDollar OR dbt:unitedArabEmiratesDirham OR dbt:bangladeshiTaka OR dbt:nigerianNaira OR dbt:rwandaFranc OR dbt:saudiRiyal OR dbt:ugandaShilling OR dbt:croatianKuna OR dbt:polishZłoty OR dbt:australianDollar OR dbt:indonesianRupiah OR dbt:southAfricanRand OR dbt:icelandKrona OR dbt:moroccanDirham OR dbt:indianRupee OR dbt:armenianDram OR dbt:qatariRial OR dbt:ghanaianCedi OR dbt:mexicanPeso OR dbt:ethiopianBirr OR dbt:kazakhstaniTenge OR dbt:romanianNewLeu OR dbt:kuwaitiDinar OR dbt:botswanaPula OR dbt:azerbaijaniManat OR dbt:newTaiwanDollar OR dbt:hungarianForint OR dbt:myanmaKyat OR dbt:tanzanianShilling OR dbt:georgianLari OR dbt:mauritianRupee OR dbt:malawianKwacha OR dbt:jordanianDinar OR dbt:egyptianPound OR dbt:nicaraguanCórdoba OR dbt:latvianLats OR dbt:bruneiDollar OR dbt:serbianDinar OR dbt:brazilianReal OR dbt:gambianDalasi OR dbt:colombianPeso OR dbt:algerianDinar OR dbt:argentinePeso OR dbt:israeliNewSheqel OR dbt:nepaleseRupee OR dbt:lebanesePound OR dbt:maldivianRufiyaa OR dbt:peruvianNuevoSol OR dbt:namibianDollar OR dbt:thaiBaht OR dbt:djiboutianFranc

<equityValue> dbt:usDollar OR dbt:euro OR dbt:renminbi OR dbt:japaneseYen OR dbt:sriLankanRupee OR dbt:poundSterling OR dbt:swedishKrona OR dbt:swissFranc OR dbt:danishKrone OR dbt:norwegianKrone OR dbt:canadianDollar OR dbt:czechKoruna OR dbt:polishZłoty OR dbt:southKoreanWon OR dbt:philippinePeso OR dbt:russianRouble OR dbt:malaysianRinggit OR dbt:australianDollar OR dbt:indonesianRupiah OR dbt:unitedArabEmiratesDirham OR dbt:icelandKrona OR dbt:croatianKuna OR dbt:azerbaijaniManat OR dbt:moroccanDirham OR dbt:kazakhstaniTenge OR dbt:bangladeshiTaka OR dbt:hongKongDollar OR dbt:indianRupee OR dbt:georgianLari OR dbt:qatariRial OR dbt:saudiRiyal OR dbt:egyptianPound OR dbt:botswanaPula OR dbt:southAfricanRand OR dbt:kenyanShilling OR dbt:newTaiwanDollar OR dbt:hungarianForint OR dbt:mexicanPeso OR dbt:latvianLats OR dbt:ethiopianBirr OR dbt:myanmaKyat OR dbt:serbianDinar OR dbt:nigerianNaira OR dbt:guineaFranc OR dbt:israeliNewSheqel OR dbt:jordanianDinar OR dbt:nicaraguanCórdoba OR dbt:nepaleseRupee OR dbt:iranianRial

<netIncomeValue> dbt:usDollar OR dbt:euro OR dbt:poundSterling OR dbt:japaneseYen OR dbt:renminbi OR dbt:norwegianKrone OR dbt:sriLankanRupee OR dbt:canadianDollar OR dbt:danishKrone OR dbt:swedishKrona OR dbt:philippinePeso OR dbt:swissFranc OR dbt:australianDollar OR dbt:southKoreanWon OR dbt:russianRouble OR dbt:indianRupee OR dbt:croatianKuna OR dbt:czechKoruna OR dbt:hongKongDollar OR dbt:polishZłoty OR dbt:malaysianRinggit OR dbt:unitedArabEmiratesDirham OR dbt:icelandKrona OR dbt:bangladeshiTaka OR dbt:saudiRiyal OR dbt:indonesianRupiah OR dbt:romanianNewLeu OR dbt:kuwaitiDinar OR dbt:botswanaPula OR dbt:nigerianNaira OR dbt:kazakhstaniTenge OR dbt:southAfricanRand OR dbt:newTaiwanDollar OR dbt:latvianLats OR dbt:mexicanPeso OR dbt:azerbaijaniManat OR dbt:hungarianForint OR dbt:ethiopianBirr OR dbt:georgianLari OR dbt:argentinePeso OR dbt:israeliNewSheqel OR dbt:jordanianDinar OR dbt:qatariRial OR dbt:nicaraguanCórdoba OR dbt:maldivianRufiyaa OR dbt:peruvianNuevoSol OR dbt:bosniaAndHerzegovinaConvertibleMarks OR dbt:papuaNewGuineanKina OR dbt:bulgarianLev OR dbt:singaporeDollar OR dbt:myanmaKyat OR dbt:brazilianReal OR dbt:armenianDram OR dbt:moroccanDirham OR dbt:nepaleseRupee OR dbt:westAfricanCfaFranc OR dbt:newZealandDollar OR dbt:moldovanLeu OR dbt:capeVerdeEscudo OR dbt:kenyanShilling OR dbt:omaniRial OR dbt:thaiBaht OR dbt:mozambicanMetical OR dbt:bruneiDollar

<operatingIncomeValue> dbt:usDollar OR dbt:euro OR dbt:poundSterling OR dbt:japaneseYen OR dbt:norwegianKrone OR dbt:renminbi OR dbt:sriLankanRupee OR dbt:swedishKrona OR dbt:swissFranc OR dbt:danishKrone OR dbt:canadianDollar OR dbt:southKoreanWon OR dbt:hongKongDollar OR dbt:philippinePeso OR dbt:australianDollar OR dbt:malaysianRinggit OR dbt:polishZłoty OR dbt:indianRupee OR dbt:russianRouble OR dbt:icelandKrona OR dbt:bangladeshiTaka OR dbt:croatianKuna OR dbt:czechKoruna OR dbt:indonesianRupiah OR dbt:kazakhstaniTenge OR dbt:unitedArabEmiratesDirham OR dbt:botswanaPula OR dbt:algerianDinar OR dbt:saudiRiyal OR dbt:hungarianForint OR dbt:myanmaKyat OR dbt:nigerianNaira OR dbt:georgianLari OR dbt:colombianPeso OR dbt:kuwaitiDinar OR dbt:azerbaijaniManat OR dbt:southAfricanRand OR dbt:newTaiwanDollar OR dbt:mexicanPeso OR dbt:albanianLek OR dbt:mauritianRupee OR dbt:qatariRial OR dbt:moroccanDirham OR dbt:egyptianPound OR dbt:jordanianDinar OR dbt:israeliNewSheqel OR dbt:nepaleseRupee OR dbt:maldivianRufiyaa OR dbt:peruvianNuevoSol OR dbt:latvianLats OR dbt:bruneiDollar

<Company> EXTRA rdf:type {
  rdf:type [ dbo:Company ] ;
  dbo:abstract rdf:langString + ;
  dbo:thumbnail @<Image> + ;
  dbo:wikiPageExternalLink xsd:anyURI * ;
  dbo:wikiPageID xsd:integer ;
  dbo:wikiPageLength xsd:nonNegativeInteger ;
  dbo:wikiPageRedirects xsd:anyURI * ;
  dbo:wikiPageRevisionID xsd:integer + ;
  dbo:wikiPageWikiLink xsd:anyURI * ;
  dct:subject @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  prov:wasDerivedFrom xsd:anyURI * ;
  foaf:depiction @<Image> + ;
  foaf:isPrimaryTopicOf xsd:anyURI * ;
  dbo:foundingDate xsd:date ;
  dbo:foundingYear xsd:gYear ;
  dbo:closingYear xsd:gYear ? ;
  dbo:closingDate xsd:date ? ;
  dbo:netIncome @<http://shaclshapes.org/netIncomeValueShape> ? ;
  dbo:operatingIncome @<http://shaclshapes.org/operatingIncomeValueShape> ? ;
  dbo:assets @<http://shaclshapes.org/assetsValueShape> * ;
  dbo:equity @<http://shaclshapes.org/equityValueShape> ? ;
  dbo:assetUnderManagement @<http://shaclshapes.org/assetUnderManagementValueShape> * ;
  dbo:numberOfLawyers xsd:nonNegativeInteger * ;
  dbo:numberOfEmployees xsd:nonNegativeInteger ;
  dbo:numberOfLocations xsd:nonNegativeInteger ;
  dbo:reportingMark xsd:string * ;
  dbo:formerName rdf:langString * ;
  dbo:originalName rdf:langString * ;
  dbo:slogan rdf:langString * ;
  dbo:regionServed @<Place> * ;
  dbo:foundationPlace @<City> ? ;
  dbo:headquarter @<PopulatedPlace> + ;
  dbo:locationCity @<City> + ;
  dbo:location @<Place> + ;
  dbo:country @<Country> + ;
  dbo:city @<City> * ;
  dbo:locationCountry @<Country> + ;
  dbo:subsidiary @<Company> * ;
  dbo:distributingCompany @<Company> * ;
  dbo:parentCompany @<Company> * ;
  dbo:owningCompany @<Company> * ;
  dbo:keyPerson @<Person> * ;
  dbo:foundedBy @<Agent> + ;
  dbo:owner @<Agent> + ;
  dbo:leader @<Person> * ;
  dbo:fate rdf:langString * ;
  dbo:production xsd:nonNegativeInteger * ;
  dbo:type . * ;
  dbo:genre @<Genre> * ;
  dbo:industry @<Genre> *
}

<Agent> EXTRA rdf:type {
  rdf:type [ dbo:Agent ]
}

<City> EXTRA rdf:type {
  rdf:type [ dbo:City ]
}

<Country> EXTRA rdf:type {
  rdf:type [ dbo:Country ]
}

<Genre> EXTRA rdf:type {
  rdf:type [ dbo:Genre ]
}

<Image> EXTRA rdf:type {
  rdf:type [ dbo:Image ]
}

<Person> EXTRA rdf:type {
  rdf:type [ dbo:Person ]
}

<Place> EXTRA rdf:type {
  rdf:type [ dbo:Place ]
}

<PopulatedPlace> EXTRA rdf:type {
  rdf:type [ dbo:PopulatedPlace ]
}

<core#Concept> EXTRA rdf:type {
  rdf:type [ skos:Concept ]
}
