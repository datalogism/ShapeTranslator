@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/ScientistShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/deathYear> ],
        [ sh:class <http://dbpedia.org/ontology/TimePeriod> ;
            sh:path <http://dbpedia.org/ontology/termPeriod> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/country> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/deathDate> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/deathPlace> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/doctoralAdvisor> ],
        [ sh:class <http://dbpedia.org/ontology/EducationalInstitution> ;
            sh:path <http://dbpedia.org/ontology/almaMater> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthPlace> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/title> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/nationality> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/residence> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Award> ;
            sh:path <http://dbpedia.org/ontology/award> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/notableStudent> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/imdbId> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsEndYear> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthDate> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/activeYearsStartYear> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:class <http://dbpedia.org/ontology/Sound> ;
            sh:path <http://dbpedia.org/ontology/soundRecording> ],
        [ sh:datatype xsd:gYear ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/birthYear> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:path <http://dbpedia.org/ontology/region> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/doctoralStudent> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/spouse> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:class <http://dbpedia.org/ontology/PersonFunction> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/occupation> ],
        [ sh:class <http://dbpedia.org/ontology/PoliticalParty> ;
            sh:path <http://dbpedia.org/ontology/party> ],
        [ sh:datatype rdf:langString ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/depictionDescription> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/child> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/institution> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/employer> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/citizenship> ],
        [ sh:class <http://dbpedia.org/ontology/Country> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/stateOfOrigin> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageInterLanguageLink> ],
        [ sh:hasValue <http://dbpedia.org/ontology/Scientist> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:path <http://dbpedia.org/ontology/academicAdvisor> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ] ;
    sh:targetClass <http://dbpedia.org/ontology/Scientist> .

