@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://shaclshapes.org/CityShape> a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:path owl:differentFrom ],
        [ sh:datatype <http://dbpedia.org/datatype/squareKilometre> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaTotal> ],
        [ sh:datatype <http://dbpedia.org/datatype/inhabitantsPerSquareKilometre> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/PopulatedPlace/populationDensity> ],
        [ sh:datatype xsd:integer ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageRevisionID> ],
        [ sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageDisambiguates> ],
        [ sh:class <http://dbpedia.org/ontology/PersonFunction> ;
            sh:path <http://dbpedia.org/ontology/politicalLeader> ],
        [ sh:class <http://dbpedia.org/ontology/Organisation> ;
            sh:path <http://dbpedia.org/ontology/governingBody> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/demonym> ],
        [ sh:class skos:Concept ;
            sh:path dcterms:subject ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/areaTotal> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/elevation> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/thumbnail> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/areaMetro> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/synonym> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationTotal> ],
        [ sh:class <http://dbpedia.org/ontology/Mayor> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/mayor> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageExternalLink> ],
        [ sh:path skos:exactMatch ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/areaCode> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:comment ],
        [ sh:datatype xsd:double ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationDensity> ],
        [ sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/predecessor> ],
        [ sh:datatype xsd:anyURI ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:anyURI ;
            sh:path foaf:isPrimaryTopicOf ],
        [ sh:class <http://dbpedia.org/ontology/SportsTeam> ;
            sh:path <http://dbpedia.org/ontology/team> ],
        [ sh:datatype xsd:string ;
            sh:path <http://dbpedia.org/ontology/motto> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationUrban> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageWikiLink> ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationMetro> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/abstract> ],
        [ sh:datatype <http://dbpedia.org/datatype/squareKilometre> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationDensity> ],
        [ sh:datatype xsd:anyURI ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageLength> ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://purl.org/linguistics/gold/hypernym> ],
        [ sh:class <http://dbpedia.org/ontology/Place> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/location> ],
        [ sh:datatype <http://dbpedia.org/datatype/squareKilometre> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/PopulatedPlace/areaMetro> ],
        [ sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/wikiPageID> ],
        [ sh:datatype xsd:double ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/areaLand> ],
        [ sh:class <http://dbpedia.org/ontology/Person> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/leaderName> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageInterLanguageLink> ],
        [ sh:datatype rdf:langString ;
            sh:path <http://dbpedia.org/ontology/originalName> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/district> ],
        [ sh:datatype xsd:double ;
            sh:path <http://dbpedia.org/ontology/areaWater> ],
        [ sh:datatype <http://dbpedia.org/datatype/squareKilometre> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/PopulatedPlace/area> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/area> ],
        [ sh:class <http://dbpedia.org/ontology/PopulatedPlace> ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/federalState> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <http://dbpedia.org/ontology/wikiPageRedirects> ],
        [ sh:datatype xsd:anyURI ;
            sh:path owl:sameAs ],
        [ sh:class <http://dbpedia.org/ontology/Saint> ;
            sh:path <http://dbpedia.org/ontology/saint> ],
        [ sh:class <http://dbpedia.org/ontology/Image> ;
            sh:minCount 1 ;
            sh:path foaf:depiction ],
        [ sh:hasValue <http://dbpedia.org/ontology/City> ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/utcOffset> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/postalCode> ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationMetroDensity> ],
        [ sh:datatype rdf:langString ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/leaderTitle> ],
        [ sh:datatype xsd:positiveInteger ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/populationTotalRanking> ],
        [ sh:datatype rdf:langString ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:path <http://dbpedia.org/ontology/maximumElevation> ],
        [ sh:datatype xsd:date ;
            sh:path <http://dbpedia.org/ontology/populationAsOf> ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://dbpedia.org/ontology/foundingDate> ] ;
    sh:targetClass <http://dbpedia.org/ontology/City> .

