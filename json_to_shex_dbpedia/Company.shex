start = @<Company>

<Company> EXTRA rdf:type {
  rdf:type [ <http://dbpedia.org/ontology/Company> ] ;
  <http://dbpedia.org/ontology/abstract> rdf:langString + ;
  <http://dbpedia.org/ontology/assetUnderManagement> @<http://shaclshapes.org/assetUnderManagementValueShape> * ;
  <http://dbpedia.org/ontology/assets> @<http://shaclshapes.org/assetsValueShape> * ;
  <http://dbpedia.org/ontology/city> @<City> * ;
  <http://dbpedia.org/ontology/closingDate> xsd:date ? ;
  <http://dbpedia.org/ontology/closingYear> xsd:gYear ? ;
  <http://dbpedia.org/ontology/country> @<Country> + ;
  <http://dbpedia.org/ontology/distributingCompany> @<Company_class> * ;
  <http://dbpedia.org/ontology/equity> @<http://shaclshapes.org/equityValueShape> ? ;
  <http://dbpedia.org/ontology/fate> rdf:langString * ;
  <http://dbpedia.org/ontology/formerName> rdf:langString * ;
  <http://dbpedia.org/ontology/foundationPlace> @<City> ? ;
  <http://dbpedia.org/ontology/foundedBy> @<Agent> + ;
  <http://dbpedia.org/ontology/foundingDate> xsd:date ;
  <http://dbpedia.org/ontology/foundingYear> xsd:gYear ;
  <http://dbpedia.org/ontology/genre> @<Genre> * ;
  <http://dbpedia.org/ontology/headquarter> @<PopulatedPlace> + ;
  <http://dbpedia.org/ontology/industry> @<Genre> * ;
  <http://dbpedia.org/ontology/keyPerson> @<Person> * ;
  <http://dbpedia.org/ontology/leader> @<Person> * ;
  <http://dbpedia.org/ontology/location> @<Place> + ;
  <http://dbpedia.org/ontology/locationCity> @<City> + ;
  <http://dbpedia.org/ontology/locationCountry> @<Country> + ;
  <http://dbpedia.org/ontology/netIncome> @<http://shaclshapes.org/netIncomeValueShape> ? ;
  <http://dbpedia.org/ontology/numberOfEmployees> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/numberOfLawyers> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/numberOfLocations> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/operatingIncome> @<http://shaclshapes.org/operatingIncomeValueShape> ? ;
  <http://dbpedia.org/ontology/originalName> rdf:langString * ;
  <http://dbpedia.org/ontology/owner> @<Agent> + ;
  <http://dbpedia.org/ontology/owningCompany> @<Company_class2> * ;
  <http://dbpedia.org/ontology/parentCompany> @<Company_class3> * ;
  <http://dbpedia.org/ontology/production> xsd:nonNegativeInteger * ;
  <http://dbpedia.org/ontology/regionServed> @<Place> * ;
  <http://dbpedia.org/ontology/reportingMark> xsd:string * ;
  <http://dbpedia.org/ontology/slogan> rdf:langString * ;
  <http://dbpedia.org/ontology/subsidiary> @<Company_class4> * ;
  <http://dbpedia.org/ontology/thumbnail> @<Image> + ;
  <http://dbpedia.org/ontology/type> . * ;
  <http://dbpedia.org/ontology/wikiPageExternalLink> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageID> xsd:integer ;
  <http://dbpedia.org/ontology/wikiPageLength> xsd:nonNegativeInteger ;
  <http://dbpedia.org/ontology/wikiPageRedirects> xsd:anyURI * ;
  <http://dbpedia.org/ontology/wikiPageRevisionID> xsd:integer + ;
  <http://dbpedia.org/ontology/wikiPageWikiLink> xsd:anyURI * ;
  <http://purl.org/dc/terms/subject> @<core#Concept> * ;
  rdf:type . + ;
  rdfs:comment rdf:langString + ;
  rdfs:label rdf:langString + ;
  owl:differentFrom xsd:anyURI * ;
  owl:sameAs xsd:anyURI * ;
  <http://www.w3.org/ns/prov#wasDerivedFrom> xsd:anyURI * ;
  <http://xmlns.com/foaf/0.1/depiction> @<Image> + ;
  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> xsd:anyURI *
}

