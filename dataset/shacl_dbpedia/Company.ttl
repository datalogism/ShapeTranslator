<http://shaclshapes.org/CompanyShape> a sh:NodeShape ;
    sh:targetClass dbo:Company ;

    # === DBpedia Common Properties ===
    sh:property [
        sh:path dbo:abstract ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:thumbnail ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageExternalLink ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageLength ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRedirects ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageRevisionID ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:wikiPageWikiLink ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://dbpedia.org/resource/" ;
    ] ;

    sh:property [
        sh:path dct:subject ;
        sh:class skos:Concept ;
    ] ;

    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:comment ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path rdfs:label ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path owl:differentFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path owl:sameAs ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:datatype xsd:anyURI ;
    ] ;

    sh:property [
        sh:path foaf:depiction ;
        sh:class dbo:Image ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path foaf:isPrimaryTopicOf ;
        sh:datatype xsd:anyURI ;
    ] ;

    # === Dates & timeline ===
    sh:property [
        sh:path dbo:foundingDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:foundingYear ;
        sh:datatype xsd:gYear ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:closingYear ;
        sh:datatype xsd:gYear ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:closingDate ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
    ] ;

    # === Economics & statistics ===
    sh:property [
        sh:path dbo:netIncome ;
        sh:node shapes:netIncomeValueShape ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:operatingIncome ;
        sh:node shapes:operatingIncomeValueShape ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:assets ;
        sh:node shapes:assetsValueShape ;
    ] ;

    sh:property [
        sh:path dbo:equity ;
        sh:node shapes:equityValueShape ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:assetUnderManagement ;
        sh:node shapes:assetUnderManagementValueShape ;
    ] ;

    sh:property [
        sh:path dbo:numberOfLawyers ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:numberOfEmployees ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:numberOfLocations ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # === Identity & naming ===
    sh:property [
        sh:path dbo:reportingMark ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path dbo:formerName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:originalName ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:slogan ;
        sh:datatype rdf:langString ;
    ] ;

    # === Location & geography ===
    sh:property [
        sh:path dbo:regionServed ;
        sh:class dbo:Place ;
    ] ;

    sh:property [
        sh:path dbo:foundationPlace ;
        sh:class dbo:City ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:headquarter ;
        sh:class dbo:PopulatedPlace ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:locationCity ;
        sh:class dbo:City ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:location ;
        sh:class dbo:Place ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:country ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:city ;
        sh:class dbo:City ;
    ] ;

    sh:property [
        sh:path dbo:locationCountry ;
        sh:class dbo:Country ;
        sh:minCount 1 ;
    ] ;

    # === Organization & affiliation ===
    sh:property [
        sh:path dbo:subsidiary ;
        sh:class dbo:Company ;
    ] ;

    sh:property [
        sh:path dbo:distributingCompany ;
        sh:class dbo:Company ;
    ] ;

    sh:property [
        sh:path dbo:parentCompany ;
        sh:class dbo:Company ;
    ] ;

    sh:property [
        sh:path dbo:owningCompany ;
        sh:class dbo:Company ;
    ] ;

    # === People & family ===
    sh:property [
        sh:path dbo:keyPerson ;
        sh:class dbo:Person ;
    ] ;

    sh:property [
        sh:path dbo:foundedBy ;
        sh:class dbo:Agent ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path dbo:owner ;
        sh:class dbo:Agent ;
        sh:minCount 1 ;
    ] ;

    # === Politics & governance ===
    sh:property [
        sh:path dbo:leader ;
        sh:class dbo:Person ;
    ] ;

    # === Technical & classification ===
    sh:property [
        sh:path dbo:fate ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path dbo:production ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;

    sh:property [
        sh:path dbo:type ;
    ] ;

    # === Career & achievements (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:genre ;
                sh:class dbo:Genre ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:industry ;
                sh:class dbo:Genre ;
            ]
        ]
    ) ;

    # === Dates & timeline (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:dissolutionDate ;
                sh:datatype xsd:date ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingDate ;
                sh:datatype xsd:date ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:formationDate ;
                sh:datatype xsd:date ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingDate ;
                sh:datatype xsd:date ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:revenueYear ;
                sh:datatype xsd:gYear ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingDate ;
                sh:datatype xsd:gYear ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:openingDate ;
                sh:datatype xsd:date ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingDate ;
                sh:datatype xsd:date ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    sh:or (
        [
            sh:property [
                sh:path dbo:openingYear ;
                sh:datatype xsd:gYear ;
                sh:maxCount 1 ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:foundingYear ;
                sh:datatype xsd:gYear ;
                sh:maxCount 1 ;
            ]
        ]
    ) ;

    # === Economics & statistics (alternatives) ===
    sh:or (
        [
            sh:property [
                sh:path dbo:revenue ;
                sh:datatype xsd:double ;
            ]
        ]
        [
            sh:property [
                sh:path dbo:genre ;
                sh:datatype xsd:double ;
            ]
        ]
    ) .

